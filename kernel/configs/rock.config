CONFIG_DRM_PANEL_SAMSUNG_OP_CMD_MSYNC2=n
CONFIG_DRM_PANEL_K6895V1_64_95T_ALPHA_CMD=n
CONFIG_DRM_PANEL_TIANMA_NT36672C_CPHY_VDO_90HZ_RT4801=n
