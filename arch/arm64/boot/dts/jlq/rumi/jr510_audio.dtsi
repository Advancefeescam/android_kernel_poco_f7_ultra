		wsa_cdc_dma_1_rx: jlq,msm-dai-wsa-cdc-dma-1-rx {
			compatible = "jlq,msm-dai-cdc-dma-dev";
			jlq,msm-dai-cdc-dma-dev-id = <45058>;
