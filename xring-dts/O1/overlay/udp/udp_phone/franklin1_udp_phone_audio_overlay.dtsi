&spk1 {
	status = "okay";
	reset-gpios = <&dw_gpio4 20 0>;
	irq-gpio = <&dw_gpio4 11 0x0>;
	#interrupt-parent = <&dw_gpio4>;
	#interrupts = <11 IRQ_TYPE_LEVEL_LOW>;
	cirrus,gpio2-src-sel = <2>;
};

&spk2 {
	status = "okay";
	reset-gpios = <&dw_gpio5 24 0>;
	irq-gpio = <&dw_gpio4 12 0x0>;
	#interrupt-parent = <&dw_gpio4>;
	#interrupts = <12 IRQ_TYPE_LEVEL_LOW>;
	cirrus,gpio2-src-sel = <2>;
};

&cs35l41b {
	status = "disabled";
};

&haptic1 {
	status = "okay";
	#cirrus,fw-defer = <1>;
	pinctrl-names = "default";
	pinctrl-0 = <&gpio_046_default>;
};

&cs47l92 {
	reset-gpios = <&dw_gpio3 0 0>;
	irq-gpio = <&dw_gpio1 29 0x0>;
	interrupt-parent = <&dw_gpio1>;
	interrupts = <29 IRQ_TYPE_LEVEL_LOW>;

	AVDD-supply = <&mldo8>;
	DBVDD1-supply = <&mldo8>;

	MICBIAS2 {
		cirrus,ext-cap = <0>;
		regulator-active-discharge = <1>;
		regulator-min-microvolt = <2300000>;
		regulator-max-microvolt = <2300000>;
	};

	cirrus,accdet {
		#address-cells = <1>;
		#size-cells = <0>;
		acc@1 {
			reg = <1>;
			cirrus,micd-clamp-mode = <0x0>;
			cirrus,micd-configs = <0 1 4 0 1>;
			cirrus,hpd-pins = <0 4 1 5>;
		};
	};
};

&pinctrl_configs {
    i2s0_sck_init: i2s0_sck_init {
        mux {
            pins = "PAD_GPIO_066";
            function = "GPIO";
            };
        pinconf {
            pins = "PAD_GPIO_066";
            bias-pull-down;
            drive-strength= <2>;
            slew-rate= <0>;
            input-schmitt-disable;
            input-enable;
        };
