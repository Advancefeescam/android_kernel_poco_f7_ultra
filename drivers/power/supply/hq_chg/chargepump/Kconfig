	tristate "use nuvolta chargepump charge architecture"
	default n
	help
	  Say Y to support nuvolta chargepump charge architecture.
	  Say M here if you want to compile this driver as a module.

config CHARGEPUMP_TI
	tristate "use ti chargepump charge architecture"
	default n
	help
	  Say Y to support ti chargepump charge architecture.
	  Say M here if you want to compile this driver as a module.
