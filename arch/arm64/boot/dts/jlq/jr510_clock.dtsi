			pll_ddr_out: pll_ddr_out {
				compatible = "jlq,clk-pll1143x";
				#clock-cells = <0>;
				clocks = <&clk19p2m>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkpllx-cfg0 = <PLL_DDR_CFG0
							PLL_PD_SFT
							PWR_WEBIT_DEF(1)
							PLL_ADJ_SFT
							PWR_WEBIT_DEF(0)>;
				jlq,clkpllx-cfg1 = <PLL_DDR_CFG1
							PLL_K_SFT PLL_MASK(16)
							PLL_M_SFT PLL_MASK(10)
							PLL_P_SFT PLL_MASK(6)>;
				jlq,clkpllx-cfg2 = <PLL_DDR_CFG2
							PLL_S_SFT PLL_MASK(3)>;
				jlq,clkpllx-ftbl =
					< 1500000000 1 156 16384 1>,//equle dsu
					< 1350000000 1 141 40960 1>,
					< 1200000000 1 125     0 1>,
					< 1000000000 1 104 10925 1>;
				clock-output-names = "pll_ddr_out";
			};

			pll_mif_out: pll_mif_out {
				compatible = "jlq,clk-pll1180x";
