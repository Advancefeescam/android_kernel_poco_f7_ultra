// SPDX-License-Identifier: GPL-2.0+
/dts-v1/;
#include <dt-bindings/interrupt-controller/arm-gic.h>
#include <dt-bindings/jlq/jr510/irqs.h>
#include <dt-bindings/jlq/jr510/reset.h>
#include <dt-bindings/jlq/jr510/jlq_dmas.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/clock/qcom,rpmcc.h>
#include <dt-bindings/clock/qcom,gcc-bengal.h>
#include <dt-bindings/interconnect/jr510.h>
#include <dt-bindings/jlq/jr510/qti_thermal.h>
#include <dt-bindings/jlq/jr510/jlq,clk-smd.h>

#include "skeleton.dtsi"

/ {
	compatible = "jlq,armv8", "jlq,jr510";
	jlq,msm-id     = <0x10510 1>;//todo

	interrupt-parent = <&gic>;
	#address-cells = <2>;
	#size-cells = <2>;

	aliases {
		ap_wdt0 = &wdt0;
		serial0 = &uart0;
		serial1 = &com_uart;
		serial2 = &uart1;
		pcm_i2s0 = &pcm_i2s_0;
		pcm_i2s1 = &pcm_i2s_1;
		sdhc0 = &sdhc_emmc;
		sdhc1 = &sdhc_sd;
		sdhc2 = &sdhc_sdio;
		ufshc1 = &ufshc_mem;
		syscount = &generic_timer;
		timer0 = &broadcast_timer;
		i2c3 = &i2c_3;
		i2c4 = &i2c_4;
		i2c6 = &i2c_6;
		swr0 = &swr0;
		swr1 = &swr1;
		spi0 = &ssi0;
		spi1 = &ssi1;
		spi2 = &ssi2;
	};

	memory {
		device_type = "memory";
		reg = <0 0 0 0>;
	};

	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		ramoops@0xe0000000 {
			compatible = "ramoops";
			reg = <0x00000000 0xe0000000 0 0x400000>;
			console-size=<0x200000>;
			ftrace-size=<0>;
			pmsg-size=<0x200000>;
		};

		logo_mem_region: logo_mem_region {
			reg = <0 0xA0000000 0 0xc00000>;
		};

		sdi_mem: sdi {
			reg = <0 0xA0C00000 0 0x1A00000>;
		};

		cm4_dump_mem: cm4_dump_mem {
			reg = <0 0xA2600000 0 0x80000>;
		};

		//vdsp_mem_region: vdsp_mem_region {
		//	reg = <0 0x8E900000 0 0x1000000>;
		//	no-map;
		//};

		//vdsp_user_mem: vdsp_user_mem {
		//	compatible = "shared-dma-pool";
		//	alloc-ranges = <0x0 0x88b00000 0x0 0x5E00000>;
		//	reusable;
		//	alignment = <0x0 0x400000>;
		//	size = <0x0 0x2000000>;
		//};

		/* global autoconfigured region for contiguous allocations */
		linux,cma {
			compatible = "shared-dma-pool";
			alloc-ranges = <0x0 0x98800000 0x0 0x1800000>;
			reusable;
			alignment = <0x0 0x400000>;
			size = <0x0 0x1000000>;
			linux,cma-default;
		};

		smem_mem: smem_region@0x88300000 {
			compatible = "removed-dma-pool";
			no-map;
			reg = <0x0 0x88300000 0x0 0x200000>;
		};
		pil_modem_mem: modem_region@0x80000000 {
			compatible = "removed-dma-pool";
			no-map;
			reg = <0x0 0x80000000 0x0 0x8000000>;
		};
		pil_msadp_mem: msadp_region@0x88200000 {
			compatible = "removed-dma-pool";
			no-map;
			reg = <0x0 0x88200000 0x0 0x100000>;
		};
		pil_qbl_mem: qbl_region@0x88000000 {
			compatible = "removed-dma-pool";
			no-map;
			reg = <0x0 0x88000000 0x0 0x200000>;
		};

		adsp_mem_1: adsp_mem_1_region@0x95400000 {
			reg = <0 0x95400000 0 0x2000000>;
			no-map;
		};
		adsp_mem_2: adsp_mem_2_region@0x97400000 {
			compatible = "shared-dma-pool";
			reusable;
			reg = <0 0x97400000 0 0x400000>;
		};
		adsp_mem_3: adsp_mem_3_region@0x97800000 {
			reg = <0 0x97800000 0 0x400000>;
			no-map;
		};
		adsp_mem_4:adsp_mem_4_region@0x33080000 {
			reg = <0 0x33080000 0 0x40000>;
			no-map;
		};
		wlan_msa_mem: wlan_msa_region@88700000 {
			compatible = "removed-dma-pool";
			no-map;
			reg = <0x0 0x88700000 0x0 0x200000>;
		};

		scp_share_mem: bridge_share_mem@0x98000000 {
			reg = <0 0x98000000 0 0x100000>;
			no-map;
		};

		bridge_share_mem: bridge_share_mem@0x98100000 {
			reg = <0 0x98100000 0 0x100000>;
			no-map;
		};

		sshub_share_mem: sshub_share_mem@0x98200000 {
			reg = <0 0x98200000 0 0x100000>;
			no-map;
		};
		atf_region@0x90000000 {
			reg = <0 0x90000000 0 0x200000>;
			no-map;
		};
		jtee_region@0x90200000 {
			reg = <0 0x90200000 0 0x5000000>;
			no-map;
		};
		npu_reserved: npu_reserved@0x98300000 {
			reg = <0x0 0x98300000 0x0 0x00500000>;
		};
	};

	timer {
		clock-frequency = <19200000>;
	};

	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};
#ifdef CONFIG_MICROTRUST_TEE_SUPPORT
	utos {
		compatible = "microtrust,utos";
		interrupts = <GIC_SPI 218 IRQ_TYPE_EDGE_RISING>,
			<GIC_SPI 72 IRQ_TYPE_EDGE_RISING>;
	};
	utos_tester {
		compatible = "microtrust,tester-v1";
	};
#endif

	cpus {
		#address-cells = <2>;
		#size-cells = <0>;

		cpu-map {
			cluster0:cluster0 {
				#cooling-cells = <2>; /* min followed by max */
				core0 {
					cpu = <&a55_cpu0>;
				};
				core1 {
					cpu = <&a55_cpu1>;
				};
				core2 {
					cpu = <&a55_cpu2>;
				};
				core3 {
					cpu = <&a55_cpu3>;
				};
				core4 {
					cpu = <&a55_cpu4>;
				};
				core5 {
					cpu = <&a55_cpu5>;
				};
				core6 {
					cpu = <&a55_cpu6>;
				};
				core7 {
					cpu = <&a55_cpu7>;
				};
			};

		};

		idle-states {
			entry-method = "arm,psci";
			CPU_OFF_LIT: pm-cpu-level0 {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x1010012>;
				//arm,psci-suspend-param = <0x0010012>;
				local-timer-stop;
				entry-latency-us = <100>;
				exit-latency-us = <100>;
				min-residency-us = <5000>;
			};
			CPU_OFF_BIG: pm-cpu-level1 {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x1010012>;
				//arm,psci-suspend-param = <0x0010012>;
				local-timer-stop;
				entry-latency-us = <100>;
				exit-latency-us = <100>;
				min-residency-us = <5000>;
			};
			CLUSTER_OFF: pm-cluster-level {
				compatible = "arm,idle-state";
				//arm,psci-suspend-param = <0x0010002>;//TODO
				entry-latency-us = <30>;
				exit-latency-us = <300>;
				min-residency-us = <4000>;
			};
		};
		a55_cpu0: cpu@400 {
			device_type = "cpu";
			compatible = "arm,cortex-a55", "arm,armv8";
			reg = <0x0 0x400>;
			enable-method = "psci";
			#cooling-cells = <2>;
			clocks = <&cpu_big_core_clk_src>;
			cpu-idle-states = <&CPU_OFF_BIG>;
			operating-points-v2 = <&big_core_opp_table>;
			cpu-supply = <&S1A>;
			capacity-dmips-mhz=<1024>;
			dynamic-power-coefficient = <191>;
			next-level-cache = <&A55_L2>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <128>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
		};
		a55_cpu1: cpu@500 {
			device_type = "cpu";
			compatible = "arm,cortex-a55", "arm,armv8";
			reg = <0x0 0x500>;
			enable-method = "psci";
			clocks = <&cpu_big_core_clk_src>;
			cpu-idle-states = <&CPU_OFF_BIG>;
			operating-points-v2 = <&big_core_opp_table>;
			dynamic-power-coefficient = <191>;
			cpu-supply = <&S1A>;
			capacity-dmips-mhz=<1024>;
			next-level-cache = <&A55_L2>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <128>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
		};

		a55_cpu2: cpu@600 {
			device_type = "cpu";
			compatible = "arm,cortex-a55", "arm,armv8";
			reg = <0x0 0x600>;
			enable-method = "psci";
			cpu-idle-states = <&CPU_OFF_BIG>;
			operating-points-v2 = <&big_core_opp_table>;
			dynamic-power-coefficient = <191>;
			cpu-supply = <&S1A>;
			capacity-dmips-mhz=<1024>;
			next-level-cache = <&A55_L2>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <128>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
		};
		a55_cpu3: cpu@700 {
			device_type = "cpu";
			compatible = "arm,cortex-a55", "arm,armv8";
			reg = <0x0 0x700>;
			enable-method = "psci";
			cpu-idle-states = <&CPU_OFF_BIG>;
			operating-points-v2 = <&big_core_opp_table>;
			dynamic-power-coefficient = <191>;
			cpu-supply = <&S1A>;
			capacity-dmips-mhz=<1024>;
			next-level-cache = <&A55_L2>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <128>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
		};

		a55_cpu4: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a55", "arm,armv8";
			reg = <0x0 0x0>;
			enable-method = "psci";
			#cooling-cells = <2>;
			cpu-idle-states = <&CPU_OFF_LIT>;
			clocks = <&cpu_little_core_clk_src>;
			clock-names = "cpu-clock";
			operating-points-v2 = <&little_core_opp_table>;
			dynamic-power-coefficient = <174>;
			cpu-supply = <&S1A>;
			capacity-dmips-mhz=<1024>;
			next-level-cache = <&A55_L2>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <128>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
		};

		a55_cpu5: cpu@100 {
			device_type = "cpu";
			compatible = "arm,cortex-a55", "arm,armv8";
			reg = <0x0 0x100>;
			enable-method = "psci";
			cpu-idle-states = <&CPU_OFF_LIT>;
			operating-points-v2 = <&little_core_opp_table>;
			dynamic-power-coefficient = <174>;
			cpu-supply = <&S1A>;
			clocks = <&cpu_little_core_clk_src>;
			capacity-dmips-mhz=<1024>;
			next-level-cache = <&A55_L2>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <128>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
		};

		a55_cpu6: cpu@200 {
			device_type = "cpu";
			compatible = "arm,cortex-a55", "arm,armv8";
			reg = <0x0 0x200>;
			enable-method = "psci";
			clocks = <&cpu_little_core_clk_src>;
			cpu-idle-states = <&CPU_OFF_LIT>;
			operating-points-v2 = <&little_core_opp_table>;
			dynamic-power-coefficient = <174>;
			cpu-supply = <&S1A>;
			capacity-dmips-mhz=<1024>;
			next-level-cache = <&A55_L2>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <128>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
		};

		a55_cpu7: cpu@300 {
			device_type = "cpu";
			compatible = "arm,cortex-a55", "arm,armv8";
			reg = <0x0 0x300>;
			enable-method = "psci";
			cpu-idle-states = <&CPU_OFF_LIT>;
			clocks = <&cpu_little_core_clk_src>;
			operating-points-v2 = <&little_core_opp_table>;
			dynamic-power-coefficient = <174>;
			cpu-supply = <&S1A>;
			capacity-dmips-mhz=<1024>;
			next-level-cache = <&A55_L2>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <128>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
		};

		A55_L2: l2-cache1 {
			compatible = "cache";
			cache-level = <1>;
			cache-size = <0x10000>;
			cache-line-size = <64>;
			cache-sets = <256>;
			next-level-cache = <&CLUSTER0_L3>;
		};

		CLUSTER0_L3: l3-cache1 {
			compatible = "cache";
			cache-level = <2>;
			cache-size = <0x80000>;
			cache-line-size = <64>;
			cache-sets = <512>;
		};

		big_core_opp_table: cpu_opp_table0 {
			compatible = "operating-points-v2";
			opp-shared;
			opp-200000000 {
				opp-hz = /bits/ 64 <200000000>;
				opp-microvolt = <700000 400000 1140000>;
				opp-microamp = <38000>;
				clock-latency-ns = <35000>;
			};
			opp-400000000 {
				opp-hz = /bits/ 64 <400000000>;
				opp-microvolt = <700000 400000 1140000>;
				opp-microamp = <42000>;
				clock-latency-ns = <35000>;
			};
			opp-600000000 {
				opp-hz = /bits/ 64 <600000000>;
				opp-microvolt = <700000 400000 1140000>;
				opp-microamp = <46000>;
				clock-latency-ns = <31000>;
			};
			opp-800000000 {
				opp-hz = /bits/ 64 <800000000>;
				opp-microvolt = <700000 400000 1140000>;
				opp-microamp = <46000>;
				clock-latency-ns = <31000>;
				opp-suspend;
			};
			opp-1000000000 {
				opp-hz = /bits/ 64 <1000000000>;
				opp-microvolt = <800000 400000 1140000>;
				opp-microamp = <50000>;
				clock-latency-ns = <29000>;
			};
			opp-1200000000 {
				opp-hz = /bits/ 64 <1200000000>;
				opp-microvolt = <800000 400000 1140000>;
				opp-microamp = <56000>;
				clock-latency-ns = <29000>;
			};
			opp-1350000000 {
				opp-hz = /bits/ 64 <1350000000>;
				opp-microvolt = <900000 400000 1140000>;
				opp-microamp = <60000>;
				clock-latency-ns = <29000>;
			};
			opp-1500000000 {
				opp-hz = /bits/ 64 <1500000000>;
				opp-microvolt = <900000 400000 1140000>;
				opp-microamp = <66000>;
				clock-latency-ns = <29000>;
			};

			opp-1750000000 {
				opp-hz = /bits/ 64 <1750000000>;
				opp-microvolt = <1000000 400000 1140000>;
				opp-microamp = <70000>;
				clock-latency-ns = <29000>;
			};
			opp-2000000000 {
				opp-hz = /bits/ 64 <2000000000>;
				opp-microvolt = <1000000 400000 1140000>;
				opp-microamp = <76000>;
				clock-latency-ns = <29000>;
			};
		};

		little_core_opp_table: cpu_opp_table1 {
			compatible = "operating-points-v2";
			opp-shared;
			opp-200000000 {
				opp-hz = /bits/ 64 <200000000>;
				opp-microvolt = <700000 400000 1140000>;
				opp-microamp = <38000>;
				clock-latency-ns = <35000>;
			};
			opp-400000000 {
				opp-hz = /bits/ 64 <400000000>;
				opp-microvolt = <700000 400000 1140000>;
				opp-microamp = <42000>;
				clock-latency-ns = <35000>;
			};
			opp-600000000 {
				opp-hz = /bits/ 64 <600000000>;
				opp-microvolt = <700000 400000 1140000>;
				opp-microamp = <46000>;
				clock-latency-ns = <31000>;
			};
			opp-800000000 {
				opp-hz = /bits/ 64 <800000000>;
				opp-microvolt = <700000 400000 1140000>;
				opp-microamp = <46000>;
				clock-latency-ns = <31000>;
				opp-suspend;
			};
			opp-1000000000 {
				opp-hz = /bits/ 64 <1000000000>;
				opp-microvolt = <800000 400000 1140000>;
				opp-microamp = <50000>;
				clock-latency-ns = <29000>;
			};
			opp-1200000000 {
				opp-hz = /bits/ 64 <1200000000>;
				opp-microvolt = <800000 400000 1140000>;
				opp-microamp = <56000>;
				clock-latency-ns = <29000>;
			};
			opp-1350000000 {
				opp-hz = /bits/ 64 <1350000000>;
				opp-microvolt = <900000 400000 1140000>;
				opp-microamp = <60000>;
				clock-latency-ns = <29000>;
			};
			opp-1500000000 {
				opp-hz = /bits/ 64 <1500000000>;
				opp-microvolt = <900000 400000 1140000>;
				opp-microamp = <66000>;
				clock-latency-ns = <29000>;
			};
		};
	};

	gic: interrupt-controller@30800000 {
		compatible = "arm,gic-v3";
		#interrupt-cells = <3>;
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;
		interrupt-controller;
		reg = <0x0 0x30800000 0 0x10000>,
			<0x0 0x30840000 0 0x100000>, /* redistributor region */
			<0x0 0x34510040 0 0x1c>;  /* SLPCTL_AP_SLP_INTR2WAKE_MKx */
		interrupts = <GIC_PPI 9 IRQ_TYPE_LEVEL_HIGH>;
	};

	generic_timer:timer {
		compatible = "arm,armv8-timer";
		interrupts = <GIC_PPI 13 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_PPI 14 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_PPI 11 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_PPI 10 IRQ_TYPE_LEVEL_HIGH>;
		clock-frequency = <19200000>;
	};

	soc: soc@0 { };

	firmware: firmware {
		android {
			compatible = "android,firmware";
			vbmeta {
				compatible="android,vbmeta";
				//parts = "vbmeta,boot,system,vendor,dtbo,recovery";
				parts = "vbmeta,boot,system,vendor,vbmeta_system,vendor_boot";
			};

			/*fstab {
				compatible = "android,fstab";
				vendor {
					compatible = "android,vendor";
					dev = "/dev/block/platform/0.soc/34458000.sdhci/by-name/vendor";
					type = "ext4";
					mnt_flags = "ro,barrier=1,discard";
					fsmgr_flags = "wait";
					//fsmgr_flags = "wait,slotselect,avb";
					status = "ok";
				};

				system {
					compatible = "android,system";
					dev = "/dev/block/platform/0.soc/34458000.sdhci/by-name/system";
					type = "ext4";
					mnt_flags = "ro,barrier=1,discard";
					fsmgr_flags = "wait";
					//fsmgr_flags = "wait,slotselect,avb";
					status = "ok";
				};
			};*/
		};
		optee {
			compatible = "linaro,optee-tz";
			method = "smc";
		};
	};
};

&soc {
	compatible = "simple-bus";
	reg = <0x0 0 0 0>;
	#address-cells = <1>;
	#size-cells = <1>;

	interrupt-parent = <&gic>;
	ranges = <0 0 0 0xffffffff>;

	thermal_zones: thermal-zones {
	};

	pmu {
		compatible="arm,cortex-a53-pmu";
		interrupts= <GIC_PPI 7 IRQ_TYPE_LEVEL_HIGH>;
	};

	dsu_pmu {
		compatible="arm,dsu-pmu";
		interrupts=<GIC_SPI INT_DSU_PMU_IRQ IRQ_TYPE_LEVEL_HIGH>;
		cpus = <&a55_cpu0 &a55_cpu1 &a55_cpu2 &a55_cpu3
			&a55_cpu4 &a55_cpu5 &a55_cpu6 &a55_cpu7>;
	};

	wdt0: watchdog@30707000 {
		compatible = "jlq,ap_wdt";
		reg = <0x30707000 0x1000>;
		reg-names = "wdt0_base";
		interrupts = <GIC_SPI INT_WDT0_BARK IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&wdt00_tclk>;
		clock-names = "wdt0_clk";
		clock-freq = <32768>;
		resets = <&crg_rst 0x4c 10 RESET_LOW_ACTIVE>; /* bit10 */
		reset-names = "wdt0-reset";
		jlq,bark-time = <10000>;
	};

	wdt1: watchdog@340EB000 {
		compatible = "jlq,adsp_wdt";
		reg = <0x340EB000 0x1000>, <0x340EA000 0x1000>;
		reg-names = "wdt1_base", "audio_sysctrl_base";
		interrupts = <GIC_SPI INT_WDT1_BITE IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "wdt1_bite";
		clocks = <&wdt1_tclk>, <&wdt1_pclk>;
		clock-names = "wdt1_tclk", "wdt1_pclk";
		status = "ok";
	};

	wdt3: watchdog@30709000 {
		compatible = "jlq,vdsp_wdt";
		reg = <0x30709000 0x1000>;
		reg-names = "wdt3_base";
		interrupts = <GIC_SPI INT_WDT3_BITE IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "wdt3_bite";
		clocks = <&wdt3_tclk>, <&wdt3_pclk>;
		clock-names = "wdt3_tclk", "wdt3_pclk";
		clock-freq = <32768>;
		status = "disable";
	};

	gpio: gpio@3450D000 {
		compatible = "jlq,jr510-gpio";
		reg = <0x3450D000 0x1000>, <0x34501000 0x1000>;
		reg-names = "gpio_mem", "pinctrl_mem";
		interrupts = <GIC_SPI INT_GPIO IRQ_TYPE_LEVEL_HIGH>;
		#gpio-cells = <2>;
		gpio-controller;
		#interrupt-cells = <2>;
		interrupt-controller;
		gpio-ranges = <&gpio 0 0 128>;
	};

	tsens: tsens@34500180 {
		compatible = "jlq,jr510-tsens";
		reg = <0x34500180 0x50>;
		reg-names = "tsens_base";
		interrupts = <GIC_SPI INT_PVT_INTR IRQ_TYPE_LEVEL_HIGH>,
					<GIC_SPI 204 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "tsens-upper-lower", "overheat";
		jlq,sensors = <4>;
		jlq,tsens-slope_numerator = <1>;
		jlq,tsens-slope_denominator = <16>;
		jlq,sensor-id = <0 1 2 3>;
		#thermal-sensor-cells = <1>;
	};

	crg_rst_base: crg_rst_base@34511200 {
		compatible = "syscon";
		reg = <0x34511200 0x50>;
	};

	crg_rst: rst_controller {
		compatible = "jlq,ja310-reset";
		#reset-cells = <3>;
		jlq,rst-syscon = <&crg_rst_base>;
	};

	crg_base: crg_base@fa722000 {
		compatible = "jlq,crg-base";
		reg = <0x34511000 0x1000>;
	};

	hblk_sctrl_base: hblk_sctrl_base@34459000 {
		compatible = "jlq,hblk_sctrl";
		reg = <0x34459000 0x1000>;
	};

	uart0: uart@30703000 {
		compatible = "jlq,jlq-uart";
		reg = <0x30703000 0x1000>;
		fifo_size = <16>;
		interrupts = <GIC_SPI INT_UART0 IRQ_TYPE_LEVEL_HIGH>;
		rx_dma_channel = <&ap_dmas DMAS_CH_UART0_RX 0>;
		tx_dma_channel = <&ap_dmas DMAS_CH_UART0_TX 0>;
		use_workqueue;
		clocks = <&uart0_sclk>, <&uart0_pclk>;
		clock-names = "uart_clk", "apb_pclk";
	};

	uart1: uart@30704000 {
		compatible = "jlq,jlq-uart";
		reg = <0x30704000 0x1000>, <0x34510510 4>;
		reg-names = "uart1_mem", "wkup_mem";
		fifo_size = <16>;
		interrupts = <GIC_SPI INT_UART1 IRQ_TYPE_LEVEL_HIGH>,
					<GIC_SPI INT_UART1_RX_WAKEUP IRQ_TYPE_LEVEL_HIGH>;
		rx_dma_channel = <&ap_dmas DMAS_CH_UART1_RX 0>;
		tx_dma_channel = <&ap_dmas DMAS_CH_UART1_TX 0>;
		tx_use_dma;
		rx_use_dma;
		use_workqueue;
		support_mctrl;
		support_qcom_bt;
		rts-gpio = <&gpio 3 GPIO_ACTIVE_LOW>;
		pinctrl-names = "default","sleep";
		pinctrl-0 = <&uart1_tx_rx_rts_pins &uart1_cts_pins>;
		pinctrl-1 = <&uart1_rts_pins>;
		clocks = <&uart1_sclk>, <&uart1_pclk>;
		clock-names = "uart_clk", "apb_pclk";
	};

	com_uart: uart@3450f000 {
		compatible = "jlq,jlq-uart";
		reg = <0x3450f000 0x1000>;
		interrupts = <GIC_SPI INT_COM_UART IRQ_TYPE_LEVEL_HIGH>;
		fifo_size = <16>;
		rx_dma_channel = <&top_dmas DMAS_CH_COMUART_RX 0>;
		tx_dma_channel = <&top_dmas DMAS_CH_COMUART_TX 0>;
		use_workqueue;
		pinctrl-names = "default","sleep";
		pinctrl-0 = <&com_uart_tx_rx_active>;
		pinctrl-1 = <&com_uart_tx_rx_sleep>;
		clocks = <&com_uart_sclk>, <&com_uart_pclk>;
		clock-names = "uart_clk", "apb_pclk";
	};

	broadcast_timer:timer@3070a000 {
		compatible = "jlq,dw-apb-timer";
		interrupts = <GIC_SPI INT_TIMER0 IRQ_TYPE_LEVEL_HIGH>;
		reg = <0x3070a000 0x1000>;
		clocks = <&timer0_1_clk>, <&timer0_pclk>;
		clock-names = "timer", "pclk";
		clock-freq = <19200000>;
	};

	qcom,rmtfs_sharedmem@0 {
		compatible = "qcom,sharedmem-uio";
		reg = <0x0 0x300000>;
		reg-names = "rmtfs";
		qcom,client-id = <0x00000001>;
		qcom,guard-memory;
		qcom,vm-nav-path;
	};

	tcsr_mutex_block: syscon@0x24D10000 {
		compatible = "syscon";
		reg = <0x24D10000 0x80>;
	};

	tcsr_mutex: hwlock {
		compatible = "qcom,tcsr-mutex";
		syscon = <&tcsr_mutex_block 0 0x4>;
		#hwlock-cells = <1>;
	};

	smem: qcom,smem {
		compatible = "qcom,smem";
		memory-region = <&smem_mem>;
		hwlocks = <&tcsr_mutex 3>;
	};

	rpm_msg_ram: memory@0245f0000 {
		compatible = "qcom,rpm-msg-ram";
		reg = <0x245f0000 0x7000>;
	};

	apcs_glb: mailbox@03450e2fc {
		compatible = "jlq,jr510-apcs-global";
		reg = <0x3450e2fc 0x1000>;

		#mbox-cells = <1>;
	};

	pcm_i2s_0: pcm_i2s@340e8000 {
		compatible = "jlq,jlq-i2s";
		reg = <0x340e8000 0x1000>;
		//rx_dma_channel = <&top_dmas DMAS_CH_I2S0_RX 0>;
		//tx_dma_channel = <&top_dmas DMAS_CH_I2S0_TX 0>;
		clocks = <&i2s0_clk>;
		clock-names = "jlq_i2s_clk";
		clock_rate = <24576000>;
		i2s_id = <0>;
		i2s_ms_mode = <1>;
		i2s_delay_mode = <0>;
		i2s_format = <1>;
		i2s_bits_per_sample = <16>;
		i2s_channels = <2>;
		i2s_rate = <48000>;
		status = "disable";
	};

	pcm_i2s_1: pcm_i2s@340e9000 {
		compatible = "jlq,jlq-i2s";
		reg = <0x340e9000 0x1000>;
		//rx_dma_channel = <&top_dmas DMAS_CH_I2S1_RX 0>;
		//tx_dma_channel = <&top_dmas DMAS_CH_I2S1_TX 0>;
		clocks = <&i2s1_clk>;
		clock-names = "jlq_i2s_clk";
		clock_rate = <24576000>;
		i2s_id = <1>;
		i2s_ms_mode = <1>;
		i2s_delay_mode = <0>;
		i2s_format = <1>;
		i2s_bits_per_sample = <16>;
		i2s_channels = <2>;
		i2s_rate = <48000>;
		status = "disable";
	};

	top_mbox_irq_sec: top_mbox_irq_sec {
		compatible = "jlq,top-mbox-irq-sec";
		reg = <0x34500000 0x18>;
		interrupts = <GIC_SPI INT_MAILBOX_APSEC IRQ_TYPE_LEVEL_HIGH>;
		interrupt-controller;
		#interrupt-cells = <2>;
		irq_num = <32>;
	};

	top_mbox_irq_cm4nsec: top_mbox_irq_cm4nsec {
		compatible = "jlq,top-mbox-irq-cm4nosec";
		reg = <0x34500030 0x18>;
		interrupts = <GIC_SPI INT_MBOX_CM42AP IRQ_TYPE_LEVEL_HIGH>;
		interrupt-controller;
		#interrupt-cells = <2>;
		irq_num = <32>;
	};

	top_mbox_irq_adspnsec: top_mbox_irq_adspnsec {
		compatible = "jlq,top-mbox-irq-adspnosec";
		reg = <0x34500360 0x20>;
		interrupts = <GIC_SPI INT_MBOX_ADSP2AP IRQ_TYPE_LEVEL_HIGH>;
		interrupt-controller;
		#interrupt-cells = <2>;
		irq_num = <32>;
	};

	top_mbox_irq_vdspnsec: top_mbox_irq_vdspnsec {
		compatible = "jlq,top-mbox-irq-vdspnosec";
		reg = <0x34500380 0x20>;
		interrupts = <GIC_SPI INT_MBOX_VDSP2AP IRQ_TYPE_LEVEL_HIGH>;
		interrupt-controller;
		#interrupt-cells = <2>;
		irq_num = <32>;
	};

	top_mailbox_base: top_mailbox_base@34500000 {
		compatible = "jlq,top-mailbox-base";
		reg = <0x34500000 0x1000>;
		status = "disabled";
	};

	bridge_sensorhub: bridge_sensorhub {
		compatible = "jlq,bridge";
		status = "disabled";
		jlq,bridge-edge = <TO_CM4>;
		jlq,bridge-name = "SENSORHUB";
		reg = <0x3307F000 0x1000>,
			<0x34500060 0x4>,
			<0x130 0x120>,
			<0x0 0x120>;
		reg-names = "baseaddr","irqtrig_addr","rx_addr","tx_addr";
		interrupt-parent = <&top_mbox_irq_cm4nsec>;
		interrupts = <0 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "rx_irq";
		jlq,bridge-tx-irq = <0>;
	};

	bridge_clk: bridge_clk {
		compatible = "jlq,bridge";
		status = "okay";
		jlq,bridge-edge = <TO_CM4_LPM>;
		jlq,bridge-name = "CLK";
		reg = <0x98100000 0x800>,
			<0x34500048 0x4>,
			<0xB0 0xA0>,
			<0x00 0xA0>;
		reg-names = "baseaddr","irqtrig_addr","rx_addr","tx_addr";
		interrupt-parent = <&top_mbox_irq_sec>;
		interrupts = <2 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "rx_irq";
		jlq,bridge-tx-irq = <2>;
	};

	bridge_vregulator: bridge_vregulator {
		compatible = "jlq,bridge";
		status = "okay";
		jlq,bridge-edge = <TO_CM4_LPM>;
		jlq,bridge-name = "VREGULATOR";
		reg = <0x98100000 0x800>,
			<0x34500048 0x4>,
			<0x2B0 0xA0>,
			<0x200 0xA0>;
		reg-names = "baseaddr","irqtrig_addr","rx_addr","tx_addr";
		interrupt-parent = <&top_mbox_irq_sec>;
		interrupts = <3 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "rx_irq";
		jlq,bridge-tx-irq = <3>;
	};

	bridge_ddr: bridge_ddr {
		compatible = "jlq,bridge";
		jlq,bridge-edge = <TO_CM4_LPM>;
		jlq,bridge-name = "DDR";
		reg = <0x98100000 0x800>,
			<0x34500048 0x4>,
			<0x4B0 0xA0>,
			<0x400 0xA0>;
		reg-names = "baseaddr","irqtrig_addr","rx_addr","tx_addr";
		interrupt-parent = <&top_mbox_irq_sec>;
		interrupts = <4 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "rx_irq";
		jlq,bridge-tx-irq = <4>;
	};

	bridge_audio: bridge_audio {
		compatible = "jlq,bridge";
		jlq,bridge-edge = <TO_ADSP>;
		jlq,bridge-name = "AUDIO";
		reg = <0x97bff000 0x1000>,
			<0x34500340 0x18>,
			<0x210 0x200>,
			<0x0 0x200>;
		reg-names = "baseaddr","irqtrig_addr","rx_addr","tx_addr";
		interrupt-parent = <&top_mbox_irq_adspnsec>;
		interrupts = <0 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "rx_irq";
		jlq,bridge-tx-irq = <0>; /*Non-Secure irq : id*/
	};

	nanohub: nanohub {
		compatible = "jlq,nanohub";
		reg = <0x34104000 0x1000>;
		/* ssi1 in sensorhub*/
		interrupt-parent = <&top_mbox_irq_cm4nsec>;
		interrupts = <1 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "apwakeup";
		sensorhub,wakelock = <1>;
		sensorhub,cm4gpios = <0x00000072>;
		pinctrl-names = "default";
		pinctrl-0 = <&spi1_tx_pin &spi1_rx_clk_pins &cm4gpio_general
				&cm4gpio_pull &cm4gpio_nopull &i2c5_pins>;
	};

	smmu: smmu@34200000 {
		compatible = "arm,smmu-v3";
		reg = <0x34200000 0xc0000>;
		interrupts =
			<GIC_SPI INT_SMMU_EVENT_Q_NS IRQ_TYPE_EDGE_RISING>,
			<GIC_SPI INT_SMMU_GERROR_NS IRQ_TYPE_EDGE_RISING>;
		interrupt-names = "eventq", "gerror";
		#iommu-cells = <1>;
		tcu-supply = <&smmu_tcu_gdsc>;
	};

	jlq,ion {
		compatible = "jlq,jlq-ion";
		#address-cells = <1>;
		#size-cells = <0>;

		jlq_system_heap: jlq,ion-heap@1025 {
			reg = <1025>;
			jlq,ion-heap-type = "JLQ_SYSTEM";
		};
	};

	gpu: gpu@30400000 {
		compatible = "arm,mali-g52", "arm,mali-bifrost";
		status = "okay";
		reg = <0x30400000 0x10000>;
		interrupts = <GIC_SPI INT_GPU_JOB IRQ_TYPE_LEVEL_HIGH>,
			<GIC_SPI INT_GPU_MMU IRQ_TYPE_LEVEL_HIGH>,
			<GIC_SPI INT_GPU_GPU IRQ_TYPE_LEVEL_HIGH>,
			<GIC_SPI INT_GPU_IRQEVENT IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "JOB", "MMU", "GPU", "EVENT";
		clocks = <&gpu_clk>;
		clock-names = "clk_mali";
		mali-supply = <&S3A_LEVEL>;
		operating-points-v2 = <&gpu_opp_table>;
		interconnect-names = "gpu-ddr";
		interconnects = <&bus_sw1 MASTER_GPU_BUS
				&bus_sw1 SLAVE_DDR_PORT4>;
		/* The power model properties need to be configured according
		   to real chip test.
		   Current property values are from arm example. which is
		   just for verifying software on emulation platform.
		*/
		ipa-model = "mali-simple-power-model";
		power_model@gpu_ipa0 {
			compatible = "arm,mali-simple-power-model";
			static-coefficient = <50934>;
			dynamic-coefficient = <1434>;
			ts = <1000000 0 0 0>;
			thermal-zone = "tsens_tz_sensor1";
		};
		power_model@gpu_ipa1 {
			compatible = "arm,mali-g52_r1-power-model";
			scale = <3>;
		};
	};
	gpu_opp_table: gpu_opp_table0 {
		compatible = "operating-points-v2", "operating-points-v2-mali";
		opp-800000000 {
			opp-hz = /bits/ 64 <800000000>;
			opp-hz-real = /bits/ 64 <800000000>;
			opp-microvolt = <800000 800000 800000>;
		};
		/* opp-692428711 {
			opp-hz = /bits/ 64 <692428711>;
			opp-hz-real = /bits/ 64 <692428711>;
			opp-microvolt = <800000 800000 800000>;
		};
		*/
		opp-519321533 {
			opp-hz = /bits/ 64 <519321533>;
			opp-hz-real = /bits/ 64 <519321533>;
			opp-microvolt = <700000 700000 800000>;
		};
		/* opp-400000000 {
			opp-hz = /bits/ 64 <400000000>;
			opp-hz-real = /bits/ 64 <400000000>;
			opp-microvolt = <700000 700000 800000>;
		};
		*/
		opp-346214355 {
			opp-hz = /bits/ 64 <346214355>;
			opp-hz-real = /bits/ 64 <346214355>;
			opp-microvolt = <700000 700000 800000>;
		};
		/* opp-200000000 {
			opp-hz = /bits/ 64 <200000000>;
			opp-hz-real = /bits/ 64 <200000000>;
			opp-microvolt = <700000 700000 800000>;
		};
		opp-100000000 {
			opp-hz = /bits/ 64 <100000000>;
			opp-hz-real = /bits/ 64 <100000000>;
			opp-microvolt = <700000 700000 800000>;
			opp-suspend;
			opp-mali-errata-1485982;
		};
		*/
	};
	vpu: mali-v500@30500000 {
		compatible = "arm,mali-v500";
		reg = <0x30500000 0x1000>,
			<0x30501000 0x1000>,
			<0x34510200 0x10>;
		reg-names = "vpu_core_mem",
			"vpu_subsys_mem",
			"vpu_lpm_mem";
		interrupts = <GIC_SPI INT_VPU IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&top_vpu_coreclk>;
		clock-names = "vpu_clk";
		vpu-supply = <&S3A_LEVEL>;
		operating-points-v2 = <&vpu_opp_table>;
		interconnect-names = "vpu-ddr";
		interconnects = <&bus_sw1 MASTER_VPU_BUS
				&bus_sw1 SLAVE_DDR_PORT4>;
	};
	vpu_opp_table: vpu_opp_table0 {
		compatible = "operating-points-v2";
		opp-692428711 {
			opp-hz = /bits/ 64 <692428711>;
			opp-hz-real = /bits/ 64 <692428711>;
			opp-microvolt = <800000 800000 800000>;
		};
		opp-519321533 {
			opp-hz = /bits/ 64 <519321533>;
			opp-hz-real = /bits/ 64 <519321533>;
			opp-microvolt = <700000 700000 800000>;
		};
		opp-400000000 {
			opp-hz = /bits/ 64 <400000000>;
			opp-hz-real = /bits/ 64 <400000000>;
			opp-microvolt = <700000 700000 800000>;
		};
	};
	vdsp: vdsp {
		compatible = "jlq,vdsp-hw-vp6,cma";
		reg = <0x30000000 0x40000>,
			<0x30090000 0x1000>,
			<0x34500320 0x10>,
			<0x0 0x200000>,
			<0x200000 0x200000>,
			<0x400000 0x700000>,
			<0xB00000 0x100000>,
			<0xC00000 0x200000>,
			<0xE00000 0x100000>,
			<0xF00000 0x100000>,
			<0x1000000 0x7F000000>;
		reg-names = "vdsp_tcm_mem",
			"vdsp_sysctl_mem",
			"irqtrig_addr",
			"code-region",
			"code-backup-region",
			"reserved-region",
			"param-region",
			"sysdump-region",
			"log-sys-region",
			"smd-sys-region",
			"dynamic-alloc-region";
		//vdsp-priv-mem = <&vdsp_mem_region>;
		vdsp-start-addr = <0x80000000>;
		interrupt-parent = <&top_mbox_irq_vdspnsec>;
		interrupts = <0 IRQ_TYPE_LEVEL_HIGH>,
			<2 IRQ_TYPE_LEVEL_HIGH>,
			<3 IRQ_TYPE_LEVEL_HIGH>,
			<4 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "smd-irq-id",
				"panic-irq-id",
				"wdog-irq-id",
				"rtc-irq-id";
		iommus = <&smmu 0x100>;
		clocks = <&vdsp_coreclk>, <&vdsp_bclk>, <&vdsp_pbclk>;
		clock-names = "coreclk", "bus-clk", "debug-clk";
		is-debug-enable = <0>;
		is-support-smmu = <1>;
		tbu-supply = <&smmu_tbu_gdsc>;
		core-supply = <&S3A_LEVEL>;
		operating-points-v2 = <&vdsp_opp_table>;
		device-irq = <0 1 0>; /* SMD IRQ_NUM, type(SECURE(0)/NON_SECURE(1)), reserved */
		device-irq-mode = <1>; /* VDSP_IRQ_LEVEL */
		host-irq = <0 1>; /* IRQ_NUM, type(SECURE(0)/NON_SECURE(1)) */
		host-irq-mode = <1>; /* VDSP_IRQ_LEVEL */
		queue-priority = <7>;
		force_ramdump_tx_irq = <2>;
		/* log_enable:0 or 1; output_mode:enum log_output_mode; */
		/* output_modules:enum log_output_modules; log_level:enum log_output_levels; */
		/* fifo_depth; fifo_width; fifo_watermark */
		log_init_setting = <1 2 128 1 256 256 10>;
		interconnect-names = "vdsp-ddr";
		interconnects = <&bus_sw0 MASTER_VDSP_BUS
				&bus_sw0 SLAVE_DDR_PORT1>;
		//jlq,tz_verify;
		status = "disable";
	};

	vdsp_opp_table: vdsp_opp_table0 {
		compatible = "operating-points-v2";

		opp-800000000 {
			opp-hz = /bits/ 64 <800000000>;
			opp-microvolt = <800000 700000 800000>;
		};
		opp-692429400 {
			opp-hz = /bits/ 64 <692000000>;
			opp-microvolt = <800000 700000 800000>;
		};
		opp-519322000 {
			opp-hz = /bits/ 64 <519000000>;
			opp-microvolt = <700000 700000 800000>;
		};
		opp-400000000 {
			opp-hz = /bits/ 64 <400000000>;
			opp-microvolt = <700000 700000 800000>;
		};
		opp-346214000 {
			opp-hz = /bits/ 64 <346000000>;
			opp-microvolt = <700000 700000 800000>;
		};
		opp-200000000 {
			opp-hz = /bits/ 64 <200000000>;
			opp-microvolt = <700000 700000 800000>;
		};
		opp-100000000 {
			opp-hz = /bits/ 64 <100000000>;
			opp-microvolt = <700000 700000 800000>;
		};
	};

	vdsp_log: vdsp_log {
		compatible = "jlq,vdsp-log";
		interrupt-parent = <&top_mbox_irq_vdspnsec>;
		interrupts = <1 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "log-irq-id";
		reg = <0x34500320 0x10>;
		reg-names = "log_irq_base";
		status = "disable";
	};

	fde: fde@3445a000 {
		compatible = "jlq,fde";
		reg = <0x3445a000 0x1000>, <0x34459000 0x1000>;
		reg-names = "fde_base", "hblkctrl_base";
		context-resverdbits = <0x80000001>;
		clocks = <&fbe_clk>, <&fbe_bus_clk>;
		clock-names = "fbe_clk", "fbe_bus_clk";
		default-clk-rate = <400000000>;
		default-bus-clk-rate = <200000000>;
		jlq,clk-rates = <100000000 266666666 400000000>;
		jlq,bus-clk-rates = <100000000 160000000 200000000>;
	};
/*
