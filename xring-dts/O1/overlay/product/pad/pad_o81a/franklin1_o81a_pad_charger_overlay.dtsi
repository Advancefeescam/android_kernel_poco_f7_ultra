&strategy_fg {
	status = "okay";

	fg_type = <2>;
	report-full-rsoc = <9500>;
	soc-proportion = <95>;
	soc-proportion-c = <94>;
	vcutoff_shutdown_delay = <3250>;
	vcutoff_sw = <3150>;
	fg_hightemp_vterm = <4200>;
	//support-full-curr-monitor;
	support-vpack-low-shutdown;
	support-pnc;

	/*get factory aging test cyclecount and volt*/
	/*batt_cyclecount  vout_threshold*/
	full-volt-monitor = <
		301 9020
		101 9060
		0 9100
	>;
	adapt_power = <120>;
	model-name = "O81A_10610mah_120w";
	support_dtpt = <1>;
	support-base-flip;
	support-lossless-rechg = <0>;
	charge-full-design = <10610>;
	lossless_rechg_cfg = <15 47 300>;
	support_normal_force_full;
	sdp_decrease_iterm = <62 62>;
	iterm_para =
		"0", "iterm_base",
		"1", "iterm_flip";
	/* temp, temp_hys, normal_iterm, ffc_iterm*/
