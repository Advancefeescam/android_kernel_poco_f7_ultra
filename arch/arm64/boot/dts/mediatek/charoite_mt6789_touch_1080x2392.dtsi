/* TOUCH start */
&spi1 {
	mediatek,pad-select = <0>,<1>;
	focaltech@0 {
		mediatek,fifo-polling = <1>;
		compatible = "focaltech,fts";
		reg = <0>;
		status = "ok";
		//panel = <&dsi_panel_n6_42_0d_0a_dsc_vdo_lcm_drv>;
		spi-max-frequency = <12000000>;
		interrupt-parent = <&pio>;
		interrupts = <1 0x2>;
		focaltech,avdd-name = "avdd";
		focaltech,avdd-gpio = <&pio 53 0x00>;
		focaltech,iovdd-name = "iovdd";
		focaltech,iovdd-gpio = <&pio 157 0x00>;
		focaltech,reset-gpio =  <&pio 152 0x00>;
		focaltech,irq-gpio = <&pio 9 0x2001>;
		focaltech,max-touch-number = <10>;
		focaltech,display-coords =  <0 0 17280 38272>;
		focaltech,touch-range-array = <1 5 10 15 20>;
		focaltech,touch-def-array = <4 3 3 3>;
		focaltech,touch-expert-array = <10 15 10 10
						20 15 15 10
						15 15 20 10>;
	};

	goodix-touch@1 {
		mediatek,fifo-polling = <1>;
		compatible = "goodix,9916k-spi";
		reg = <1>;
		status = "ok";
		spi-max-frequency = <15000000>;
		interrupt-parent = <&pio>;
		interrupts = <9 0x2001>;
		goodix,avdd-name = "avdd";
		goodix,avdd-gpio = <&pio 53 0x00>;
		goodix,iovdd-name = "iovdd";
		goodix,iovdd-gpio = <&pio 157 0x00>;
		goodix,reset-gpio = <&pio 152 0x0>;
		goodix,irq-gpio = <&pio 9 0x2001>;
		goodix,irq-flags = <2>; /* 1:trigger rising, 2:trigger falling; */
		goodix,panel-max-x = <17280>;
		goodix,panel-max-y = <38272>;
		goodix,panel-max-w = <255>;
		/* optional properties */
		goodix,panel-max-p = <4096>; /* max pressure that pen device supported */
		//goodix,pen-enable; /* support active stylus device*/
		goodix,sleep-enable; /* enter sleep mode */
		//goodix,firmware-name = "gt9916_ts_fw_vsn.bin";
		//goodix,config-name = "goodix_cfg_group_vsn.bin";
		goodix,touch-expert-array = <2 3 2 2
					     4 3 3 2
					     3 3 4 2>;
	};
};
/* TOUCH end */
