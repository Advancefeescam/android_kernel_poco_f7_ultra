#============================= BSP-Fingerprint begin =============================
CONFIG_TRUSTONIC_TRUSTED_UI=n
CONFIG_GOODIX_FINGERPRINT=m
CONFIG_FPC_FINGERPRINT=m
CONFIG_MTK_FINGERPRINT_SUPPORT=m
CONFIG_SPI_MT65XX_MODULE=y
#============================= BSP-Fingerprint end ===============================


#=============================== BSP-Charger begin ===============================
CONFIG_USB_POWER_DELIVERY=n
CONFIG_TCPC_WUSB3801=m
CONFIG_TCPC_FUSB303=m
CONFIG_CHARGER_BQ2589x_charger=m
CONFIG_BATTERY_ID_ADC=m
CONFIG_CHARGER_MT6375=n
CONFIG_GAUGE_MT6375=n
CONFIG_TCPC_MT6375=n
CONFIG_MTK_BATTERY_SYSFS=m
#=============================== BSP-Charger end =================================


#=============================== BSP-Memory begin ================================
CONFIG_UFSSHPB=n
CONFIG_HPB_DEBUG=n
CONFIG_HPB_DEBUG_SYSFS=n
CONFIG_HPB_ERR_INJECTION=n
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_SECURITY=y
CONFIG_F2FS_FS_ENCRYPTION=y
CONFIG_MI_MEMORY_SYSFS=m
#=============================== BSP-Memory end ==================================


#=============================== BSP-Sensor begin ================================
CONFIG_MTK_TINYSYS_SCP_DEBUG_SUPPORT=y
#=============================== BSP-Sensor end ==================================


#=============================== BSP-Audio begin =================================
CONFIG_SWITCH=m
CONFIG_SWITCH_GPIO=m
CONFIG_SND_SOC_AW87XXX=m
#=============================== BSP-Audio end ===================================


#================================= Camera begin ==================================
CONFIG_MTK_FLASHLIGHT_LED191=m
CONFIG_CUSTOM_KERNEL_IMGSENSOR="s5kjn1_sunny_main_mipi_raw s5kjn1_ofilm_main_mipi_raw ov8856_aac_front_mipi_raw ov8856_ofilm_front_mipi_raw gc5035_sunny_front_mipi_raw hi556_ofilm_front_mipi_raw ov02b1b_sunny_depth_mipi_raw sc202cs_ofilm_depth_mipi_raw gc02m1_ofilm_macro_mipi_raw gc02m1_aac_macro_mipi_raw"
