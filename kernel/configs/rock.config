CONFIG_DRM_PANEL_ALPHA_JDI_NT36672E_VDO_60HZ=n
CONFIG_DRM_PANEL_SAMSUNG_S68FC01_VDO_AOD=n
CONFIG_DRM_PANEL_ALPHA_JDI_NT36672E_VDO_120HZ_HFP=n
CONFIG_DRM_PANEL_ALPHA_JDI_NT36672E_VDO_144HZ_HFP=n
CONFIG_DRM_PANEL_HX_NT37701_DPHY_CMD=n
CONFIG_DRM_PANEL_HX_NT37701_DPHY_CMD_120HZ=n
CONFIG_DRM_PANEL_TIANMA_NT37701A_DPHY_CMD_144HZ=n
CONFIG_DRM_PANEL_ALPHA_SAMSUNG_S6E3HAE_CMD_120HZ=n
CONFIG_DRM_PANEL_TRULY_NT35595_CMD=n
CONFIG_DRM_PANEL_SAMSUNG_ANA6705_CMD=n
