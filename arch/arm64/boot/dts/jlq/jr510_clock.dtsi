#include <dt-bindings/jlq/jr510/offset-top_crg.h>
#include <dt-bindings/jlq/jr510/offset-ai_sysctrl.h>
#include <dt-bindings/jlq/jr510/offset-cm4_sysctrl.h>
#include <dt-bindings/jlq/jr510/offset-display_sysctrl.h>
#include <dt-bindings/jlq/jr510/offset-hblk_sysctrl.h>
#include <dt-bindings/jlq/jr510/offset-vdsp_sysctrl.h>
#include <dt-bindings/jlq/jr510/offset-vpu_sysctrl.h>
#include <dt-bindings/jlq/jr510/offset-audio_sysctrl.h>
#include <dt-bindings/jlq/jr510/jlq,clk-smd.h>

/ {
	clocks: clocks@0 {
		compatible = "simple-bus";
		#address-cells = <1>;
		#size-cells = <1>;
		//ranges = <0x34511000 0 0x34511000 0xffffffff>;
		ranges = <0 0 0 0xffffffff>;

		/* fixed clock.*/
		clk32k: osc@0 {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <32768>;
			clock-output-names = "clk32k";
		};

		clk19p2m: osc@1 {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <19200000>;
			clock-output-names = "clk19p2m";
		};

		top_crg_clks: top_crg_clks@34511000 {
			compatible = "jlq,top_crg_clks";
			reg = <0x34511000 0x1000>;
		};

			top_clk_19p2m: top_clk_19p2m {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&clk19p2m>;
				clock-output-names = "top_clk_19p2m";
			};

			top_clk_32k: top_clk_32k {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&clk32k>;
				clock-output-names = "top_clk_32k";
			};

			top_clk_3p2m: top_clk_3p2m {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&clk19p2m>;
				clock-div = <6>;
				clock-mult = <1>;
				clock-output-names = "top_clk_3p2m";
			};

			pll_comm: pll_comm {
				compatible = "fixed-clock";
				#clock-cells = <0>;
				clock-frequency = <800000000>;
				clock-output-names = "pll_comm";
			};

			pll_comm_2d: pll_comm_2d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_comm>;
				clock-div = <2>;
				clock-mult = <1>;
				clock-output-names = "pll_comm_2d";
			};

			pll_comm_3d: pll_comm_3d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_comm>;
				clock-div = <3>;
				clock-mult = <1>;
				clock-output-names = "pll_comm_3d";
			};

			pll_comm_4d: pll_comm_4d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_comm>;
				clock-div = <4>;
				clock-mult = <1>;
				clock-output-names = "pll_comm_4d";
			};

			pll_comm_5d: pll_comm_5d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_comm>;
				clock-div = <5>;
				clock-mult = <1>;
				clock-output-names = "pll_comm_5d";
			};

			pll_comm_6d: pll_comm_6d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_comm>;
				clock-div = <6>;
				clock-mult = <1>;
				clock-output-names = "pll_comm_6d";
			};

			pll_comm_8d: pll_comm_8d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_comm>;
				clock-div = <8>;
				clock-mult = <1>;
				clock-output-names = "pll_comm_8d";
			};

			pll_comm_10d: pll_comm_10d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_comm>;
				clock-div = <10>;
				clock-mult = <1>;
				clock-output-names = "pll_comm_10d";
			};

			pll_comm_12d: pll_comm_12d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_comm>;
				clock-div = <12>;
				clock-mult = <1>;
				clock-output-names = "pll_comm_12d";
			};

			pll_comm_16d: pll_comm_16d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_comm>;
				clock-div = <16>;
				clock-mult = <1>;
				clock-output-names = "pll_comm_16d";
			};

			pll_opt: pll_opt {
				compatible = "fixed-clock";
				#clock-cells = <0>;
				clock-frequency = <2077286133>;
				clock-output-names = "pll_opt";
			};

			pll_opt_3d: pll_opt_3d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_opt>;
				clock-div = <3>;
				clock-mult = <1>;
				clock-output-names = "pll_opt_3d";
			};

			pll_opt_4d: pll_opt_4d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_opt>;
				clock-div = <4>;
				clock-mult = <1>;
				clock-output-names = "pll_opt_4d";
			};

			pll_opt_6d: pll_opt_6d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_opt>;
				clock-div = <6>;
				clock-mult = <1>;
				clock-output-names = "pll_opt_6d";
			};

			pll_opt_92d: pll_opt_92d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_opt>;
				clock-div = <92>;
				clock-mult = <1>;
				clock-output-names = "pll_opt_92d";
			};

			top_clk_22p5792m: top_clk_22p5792m {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_opt_4d>;
				clock-div = <23>;
				clock-mult = <1>;
				clock-output-names = "top_clk_22p5792m";
			};

			pll_i2s: pll_i2s {
				compatible = "jlq,clk-pll1143x";
				#clock-cells = <0>;
				clocks = <&clk19p2m>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkpllx-cfg0 = <PLL_I2S_CFG0
							PLL_PD_SFT
							PWR_WEBIT_DEF(1)
							PLL_ADJ_SFT
							PWR_WEBIT_DEF(0)>;
				jlq,clkpllx-cfg1 = <PLL_I2S_CFG1
							PLL_K_SFT PLL_MASK(16)
							PLL_M_SFT PLL_MASK(10)
							PLL_P_SFT PLL_MASK(6)>;
				jlq,clkpllx-cfg2 = <PLL_I2S_CFG2
							PLL_S_SFT PLL_MASK(3)>;
				jlq,clkpllx-ftbl =
					< 589824000 1 123 57672 2>;
				clock-output-names = "pll_i2s";
			};

			pll_i2s_12d: pll_i2s_12d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_i2s>;
				clock-div = <12>;
				clock-mult = <1>;
				clock-output-names = "pll_i2s_12d";
			};

			pll_i2s_24d: pll_i2s_24d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&pll_i2s>;
				clock-div = <24>;
				clock-mult = <1>;
				clock-output-names = "pll_i2s_24d";
			};

			top_clk_49p152m: top_clk_49p152m {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&pll_i2s_12d>;
				clock-output-names = "top_clk_49p152m";
			};

			top_clk_24p576m: top_clk_24p576m {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&pll_i2s_24d>;
				clock-output-names = "top_clk_24p576m";
			};

			pll_cpu_big_out: pll_cpu_big_out {
				compatible = "jlq,clk-pll1143x";
				#clock-cells = <0>;
				clocks = <&clk19p2m>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkpllx-cfg0 = <PLL_CPU_BIG_CFG0
							PLL_PD_SFT
							PWR_WEBIT_DEF(1)
							PLL_ADJ_SFT
							PWR_WEBIT_DEF(0)>;
				jlq,clkpllx-cfg1 = <PLL_CPU_BIG_CFG1
							PLL_K_SFT PLL_MASK(16)
							PLL_M_SFT PLL_MASK(10)
							PLL_P_SFT PLL_MASK(6)>;
				jlq,clkpllx-cfg2 = <PLL_CPU_BIG_CFG2
							PLL_S_SFT PLL_MASK(3)>;
				jlq,clkpllx-ftbl =
					< 2000000000 1 104 10918 0>,
					< 1875000000 1  98 43008 0>,
					< 1750000000 1  91  9557 0>,
					< 1625000000 1  85 41642 0>,
					< 1500000000 1 156 16384 1>,//equle dsu
					< 1406250000 1 146 31744 1>,
					< 1350000000 1 141 40960 1>,
					< 1312500000 1 137 47104 1>,
					< 1218750000 1 127 62464 1>,
					< 1200000000 1 125     0 1>,
					< 1000000000 1 104 10918 1>;
				clock-output-names = "pll_cpu_big_out";
			};
/*
			pll_cpu_big_out: pll_cpu_big_out {
				compatible = "fixed-clock";
				#clock-cells = <0>;
				clock-frequency = <2000000000>;
				clock-output-names = "pll_cpu_big_out";
			};
*/
			cpu_low_clk_gdiv: cpu_low_clk_gdiv {
				compatible = "jlq,clk-div";
				#clock-cells = <0>;
				clocks = <&pll_comm>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkdiv = <CPU_LOW_CLK_CTL
					PWR_MASK(3) PWR_BIT_SFT(1)
					PWR_WEBIT_DEF(1)>;
				jlq,val_min_max = <0 7>;
				jlq,gdiv;
				clock-output-names = "cpu_low_clk_gdiv";
			};

			cpu_low_clk: cpu_low_clk {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&cpu_low_clk_gdiv>;
				set_rate_parent;
				clock-output-names = "cpu_low_clk";
			};
/*
			cpu_low_clk: cpu_low_clk {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&cpu_low_clk_gdiv>;
				set_rate_parent;
				clock-output-names = "cpu_low_clk";
			};
*/
			cpu_big_core_clk_srcmux: cpu_big_core_clk_srcmux {
				compatible = "jlq,clk-mux";
				#clock-cells = <0>;
				clocks = <&cpu_low_clk &pll_cpu_big_out>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkmux = <CPU_BIG_CORE_CLK_SRC_MX_CTL
					PWR_MASK(1) PWR_BIT_SFT(1)
					PWR_WEBIT_DEF(1)>;
				set_rate_parent;
				clock-output-names = "cpu_big_core_clk_srcmux";
			};

			cpu_big_core_clk_src: cpu_big_core_clk_src {
				compatible = "jlq,clk-gate";
				#clock-cells = <0>;
				clocks = <&cpu_big_core_clk_srcmux>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkgt = <CPU_BIG_CORE_CLK_SRC_MX_CTL
					PWR_BIT_SFT(0) PWR_WEBIT_DEF(0)>;
				clk_is_critical;
				set_rate_parent;
				clock-output-names = "cpu_big_core_clk_src";
			};
/*
			cpu_big_core_clk_src: cpu_big_core_clk_src {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&cpu_big_core_clk_srcmux>;
				set_rate_parent;
				clock-output-names = "cpu_big_core_clk_src";
			};
*/

			pll_cpu_little_out: pll_cpu_little_out {
				compatible = "jlq,clk-pll1143x";
				#clock-cells = <0>;
				clocks = <&clk19p2m>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkpllx-cfg0 = <PLL_CPU_LITTLE_CFG0
							PLL_PD_SFT
							PWR_WEBIT_DEF(1)
							PLL_ADJ_SFT
							PWR_WEBIT_DEF(0)>;
				jlq,clkpllx-cfg1 = <PLL_CPU_LITTLE_CFG1
							PLL_K_SFT PLL_MASK(16)
							PLL_M_SFT PLL_MASK(10)
							PLL_P_SFT PLL_MASK(6)>;
				jlq,clkpllx-cfg2 = <PLL_CPU_LITTLE_CFG2
							PLL_S_SFT PLL_MASK(3)>;
				jlq,clkpllx-ftbl =
					< 1500000000 1 156 16384 1>,//equle dsu
					< 1406250000 1 146 31744 1>,
					< 1350000000 1 141 40960 1>,
					< 1312500000 1 137 47104 1>,
					< 1218750000 1 127 62464 1>,
					< 1200000000 1 125     0 1>,
					< 1000000000 1 104 10925 1>;
				clock-output-names = "pll_cpu_little_out";
			};
/*
			pll_cpu_little_out: pll_cpu_little_out {
				compatible = "fixed-clock";
				#clock-cells = <0>;
				clock-frequency = <1500000000>;
				clock-output-names = "pll_cpu_little_out";
			};
*/
			cpu_little_core_clk_srcmux: cpu_little_core_clk_srcmux {
				compatible = "jlq,clk-mux";
				#clock-cells = <0>;
				clocks = <&cpu_low_clk &pll_cpu_little_out>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkmux = <CPU_LITTLE_CORE_CLK_SRC_MX_CTL
					PWR_MASK(1) PWR_BIT_SFT(1)
					PWR_WEBIT_DEF(1)>;
				set_rate_parent;
				clock-output-names =
					"cpu_little_core_clk_srcmux";
			};

			cpu_little_core_clk_src: cpu_little_core_clk_src {
				compatible = "jlq,clk-gate";
				#clock-cells = <0>;
				clocks = <&cpu_little_core_clk_srcmux>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkgt = <CPU_LITTLE_CORE_CLK_SRC_MX_CTL
					PWR_BIT_SFT(0) PWR_WEBIT_DEF(0)>;
				clk_is_critical;
				set_rate_parent;
				clock-output-names = "cpu_little_core_clk_src";
			};
/*
			cpu_little_core_clk_src: cpu_little_core_clk_src {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&cpu_little_core_clk_srcmux>;
				set_rate_parent;
				clock-output-names = "cpu_little_core_clk_src";
			};
*/

			pll_dsu_out: pll_dsu_out {
				compatible = "jlq,clk-pll1143x";
				#clock-cells = <0>;
				clocks = <&clk19p2m>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkpllx-cfg0 = <PLL_DSU_CFG0
							PLL_PD_SFT
							PWR_WEBIT_DEF(1)
							PLL_ADJ_SFT
							PWR_WEBIT_DEF(0)>;
				jlq,clkpllx-cfg1 = <PLL_DSU_CFG1
							PLL_K_SFT PLL_MASK(16)
							PLL_M_SFT PLL_MASK(10)
							PLL_P_SFT PLL_MASK(6)>;
				jlq,clkpllx-cfg2 = <PLL_DSU_CFG2
							PLL_S_SFT PLL_MASK(3)>;
				jlq,clkpllx-ftbl =
					< 1500000000 1 156 16384 1>,//equle dsu
					< 1350000000 1 141 40960 1>,
					< 1200000000 1 125     0 1>,
					< 1125000000 1 117 12288 1>,
					< 1000000000 1 104 10925 1>;
				clock-output-names = "pll_dsu_out";
			};
/*
			pll_dsu_out: pll_dsu_out {
				compatible = "fixed-clock";
				#clock-cells = <0>;
				clock-frequency = <1500000000>;
				clock-output-names = "pll_dsu_out";
			};
*/
			cpu_dsu_clk_srcmux: cpu_dsu_clk_srcmux {
				compatible = "jlq,clk-mux";
				#clock-cells = <0>;
				clocks = <&cpu_low_clk &pll_dsu_out>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkmux = <CPU_DSU_CLK_SRC_MX_CTL PWR_MASK(1)
					PWR_BIT_SFT(1) PWR_WEBIT_DEF(1)>;
				set_rate_parent;
				clock-output-names = "cpu_dsu_clk_srcmux";
			};

			cpu_dsu_clk_src: cpu_dsu_clk_src {
				compatible = "jlq,clk-gate";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_srcmux>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkgt = <CPU_DSU_CLK_SRC_MX_CTL
					PWR_BIT_SFT(0) PWR_WEBIT_DEF(0)>;
				set_rate_parent;
				clk_is_critical;
				clock-output-names = "cpu_dsu_clk_src";
			};
/*
			cpu_dsu_clk_src: cpu_dsu_clk_src {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_srcmux>;
				set_rate_parent;
				clock-output-names = "cpu_dsu_clk_src";
			};
*/
			cpu_dsu_clk_src_div3: cpu_dsu_clk_src_div3 {
				compatible = "jlq,clk-div";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkdiv = <CPU_DSU_CLK_SRC_DIV3_CDIV_CTL
					PWR_MASK(3) PWR_BIT_SFT(0)
					PWR_WEBIT_DEF(0)>;
				jlq,val_min_max = <2 7>;
				jlq,cdiv;
				//set_rate_parent;
				clock-output-names = "cpu_dsu_clk_src_div3";
			};

			/*ppu auto-gate*/
			cpu_atclk: cpu_atclk {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src_div3>;
				//set_rate_parent;
				clock-output-names = "cpu_atclk";
			};

			/*ppu auto-gate*/
			cpu_pclk: cpu_pclk {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src_div3>;
				//set_rate_parent;
				clock-output-names = "cpu_pclk";
			};

			/*ppu auto-gate*/
			cpu_periphclk: cpu_periphclk {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src_div3>;
				//set_rate_parent;
				clock-output-names = "cpu_periphclk";
			};

			/*ppu auto-gate*/
			cpu_gicclk: cpu_gicclk {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src_div3>;
				//set_rate_parent;
				clock-output-names = "cpu_gicclk";
			};

			cpu_bus_clk: cpu_bus_clk {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src>;
				clock-div = <3>;
				clock-mult = <1>;
				clock-output-names = "cpu_bus_clk";
			};

			cpu_bus_from_dsu_clk: cpu_bus_from_dsu_clk {
				compatible = "jlq,clk-thru";
				#clock-cells = <0>;
				clocks = <&cpu_bus_clk>;
				//set_rate_parent;
				clock-output-names = "cpu_bus_from_dsu_clk";
			};

			dsu_gicclk: dsu_gicclk {
				compatible = "jlq,clk-gate";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src_div3>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkgt = <GIC_CLK_CG_CTL
					PWR_BIT_SFT(1) PWR_WEBIT_DEF(1)>;
				//set_rate_parent;
				clock-output-names = "dsu_gicclk";
			};

			cs_periphclk: cs_periphclk {
				compatible = "jlq,clk-gate";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src_div3>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkgt = <CS_CLK_CG_CTL
					PWR_BIT_SFT(13) PWR_WEBIT_DEF(13)>;
				//set_rate_parent;
				clock-output-names = "cs_periphclk";
			};

			cs_debugpclk: cs_debugpclk {
				compatible = "jlq,clk-gate";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src_div3>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkgt = <CS_CLK_CG_CTL
					PWR_BIT_SFT(12) PWR_WEBIT_DEF(12)>;
				//set_rate_parent;
				clock-output-names = "cs_debugpclk";
			};

			cs_a55_atbclk: cs_a55_atbclk {
				compatible = "jlq,clk-gate";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src_div3>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkgt = <CS_CLK_CG_CTL
					PWR_BIT_SFT(8) PWR_WEBIT_DEF(8)>;
				//set_rate_parent;
				clock-output-names = "cs_a55_atbclk";
			};

			cs_atbclk: cs_atbclk {
				compatible = "jlq,clk-gate";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src_div3>;
				jlq,base = <JLQ_TOP_CRG>;
				jlq,clkgt = <CS_CLK_CG_CTL
					PWR_BIT_SFT(10) PWR_WEBIT_DEF(10)>;
				//set_rate_parent;
				clock-output-names = "cs_atbclk";
			};

			cpu_dsu_clk_src_div3_2d: cpu_dsu_clk_src_div3_2d {
				compatible = "fixed-factor-clock";
				#clock-cells = <0>;
				clocks = <&cpu_dsu_clk_src_div3>;
