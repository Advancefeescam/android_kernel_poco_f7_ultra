				jlq,clkpllx-cfg1 = <DDR_PLL_MIF_CONF1
							MIF_PD_SFT
							PWR_WEBIT_DEF(5)
							MIF_ADJ_SFT
							PWR_WEBIT_DEF(4)>;
				jlq,clkpllx-ftbl =
					< 1500000000 1 156 16384 1>,//equle dsu
					< 1350000000 1 141 40960 1>,
