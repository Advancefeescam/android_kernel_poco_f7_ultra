/* M6 code  */
&i2c3 {
    nxp@28 {
        compatible = "nq-nci";
        reg = <0x28>;
        nq-irq = <&pio 1 0x00>;
        interrupt-parent = <&pio>;
        interrupts = <1 IRQ_TYPE_LEVEL_HIGH 1 0>;
        nq-ven = <&pio 96 0x0>;
        nq-firm = <&pio 106 0x0>;
        nq-clkreq = <&pio 68 0x0>;
        interrupt-names = "irq_nfc";
        status = "okay";
    };
};
