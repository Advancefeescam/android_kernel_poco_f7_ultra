		"13", "2", "262", "262",
		"18", "0", "262", "1515",
		"35", "0", "262", "2508",
		"48", "0", "262", "262";

	iterm_flip =
		"13", "2", "262", "262",
		"18", "0", "262", "1515",
		"35", "0", "262", "2508",
		"48", "0", "262", "262";
};

