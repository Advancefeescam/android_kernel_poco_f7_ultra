		rx_cdc_dma_6_rx: jlq,msm-dai-rx-cdc-dma-6-rx {
			compatible = "jlq,msm-dai-cdc-dma-dev";
			jlq,msm-dai-cdc-dma-dev-id = <45116>;
		};

		rx_cdc_dma_7_rx: jlq,msm-dai-rx-cdc-dma-7-rx {
			compatible = "jlq,msm-dai-cdc-dma-dev";
			jlq,msm-dai-cdc-dma-dev-id = <45118>;
		};

