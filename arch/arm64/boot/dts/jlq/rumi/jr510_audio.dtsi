&soc {
	clkout3_clk: clkout3_clk {
		status = "disabled";
		compatible = "jlq,clk-gate";
		#clock-cells = <0>;
		//clocks = <&clkout3_srcmux>;
		//jlq,clkgt = <DDRPWR_COMPONENT_CLKEN2
		//	PWR_BIT_SFT(8) PWR_WEBIT_DEF(8)>;
		//set_rate_parent;
		//clock-output-names = "clkout3_clk";
	};

	bolero: bolero-cdc {
		compatible = "jlq,bolero-codec";
		status = "disabled";
		jlq,num-macros = <3>;
		jlq,bolero-version = <5>;
		#address-cells = <2>;
		#size-cells = <0>;
		bolero-clk-rsc-mngr {
			compatible = "jlq,bolero-clk-rsc-mngr";
			jlq,fs-gen-sequence = <0x3000 0x1>,
						<0x3004 0x1>, <0x3080 0x2>;
			clock-names = "tx_core_clk", "tx_npl_clk", "rx_core_clk", "rx_npl_clk",
				"va_core_clk", "va_npl_clk";
			clocks = <&clkout3_clk>, <&clkout3_clk>,
				<&clkout3_clk>, <&clkout3_clk>,
				<&clkout3_clk>, <&clkout3_clk>;
		};

		tx_macro: tx-macro {
			compatible = "jlq,tx-macro";
			reg = <0x0 0x42000000>;
			clock-names = "tx_core_clk", "tx_npl_clk";
			clocks = <&clkout3_clk>,
				 <&clkout3_clk>;
			jlq,tx-dmic-sample-rate = <2400000>;
			jlq,is-used-swr-gpio = <0>;
		};

		rx_macro: rx-macro {
			compatible = "jlq,rx-macro";
			reg = <0x0 0x42000000>;
			clock-names = "rx_core_clk", "rx_npl_clk";
			clocks = <&clkout3_clk>,
				 <&clkout3_clk>;
			jlq,rx-swr-gpios = <&gpio 12 0>;
			jlq,rx_mclk_mode_muxsel = <04210000>;
			jlq,rx-bcl-pmic-params = /bits/ 8 <0x00 0x04 0x3E>;
			jlq,default-clk-id = <1>;
			swr1: rx_swr_master {
				compatible = "jlq,swr-mstr";
				#address-cells = <2>;
				#size-cells = <0>;
				clock-names = "lpass_audio_hw_vote";
				clocks = <&clkout3_clk>;
				jlq,swr_master_id = <2>;
				jlq,swrm-hctl-reg = <0x04210004>;
				jlq,mipi-sdw-block-packing-mode = <1>;
				swrm-io-base = <0x04210008 0x0>;
				//interrupt-parent = <&top_mailbox_irq>;
				interrupts = <8 0>;
				interrupt-names = "swr_master_irq";
				jlq,swr-num-ports = <5>;
				jlq,swr-num-dev = <1>;
				jlq,swr-clock-stop-mode0 = <1>;
				wcd937x_rx_slave: wcd937x-rx-slave {
					compatible = "jlq,wcd937x-slave";
					reg = <0x04210008 0x0421000c>;
				};
			};
		};

		va_macro: va-macro@ {
			compatible = "jlq,va-macro";
			reg = <0x0 0x42000000>;
			clock-names = "lpass_audio_hw_vote";
			clocks = <&clkout3_clk>;
			jlq,va-dmic-sample-rate = <600000>;
			jlq,va-clk-mux-select = <1>;
			jlq,va-island-mode-muxsel = <0x0a7a0000>;
			jlq,default-clk-id = <1>;
			jlq,is-used-swr-gpio = <1>;
			jlq,va-swr-gpios = <&gpio 12 0>;
			swr0: va_swr_master {
				compatible = "jlq,swr-mstr";
				#address-cells = <2>;
				#size-cells = <0>;
				clock-names = "lpass_audio_hw_vote";
				clocks = <&clkout3_clk>;
				jlq,swr_master_id = <3>;
				jlq,swrm-hctl-reg = <0x0a7ec100>;
				jlq,mipi-sdw-block-packing-mode = <1>;
				swrm-io-base = <0xa740000 0x0>;
				//interrupt-parent = <&top_mailbox_irq>;
				interrupts = <9 0>, <10 0>;
				interrupt-names = "swr_master_irq", "swr_wake_irq";
				jlq,swr-wakeup-required = <1>;
				jlq,swr-num-ports = <3>;
				jlq,swr-num-dev = <1>;
				jlq,swr-clock-stop-mode0 = <1>;
				jlq,swr-mstr-irq-wakeup-capable = <1>;
				wcd937x_tx_slave: wcd937x-tx-slave {
					compatible = "jlq,wcd937x-slave";
					reg = <0x0A 0x01170223>;
				};
			};
		};

		wcd937x_codec: wcd937x-codec {
			compatible = "jlq,wcd937x-codec";
			jlq,split-codec = <1>;

			jlq,wcd-rst-gpio-node = <&gpio 12 0>;
			jlq,rx-slave = <&wcd937x_rx_slave>;
			jlq,tx-slave = <&wcd937x_tx_slave>;

			//cdc-vdd-rxtx-supply = <&L9A>;
			jlq,cdc-vdd-rxtx-voltage = <1800000 1800000>;
			jlq,cdc-vdd-rxtx-current = <10000>;

			//cdc-vddpx-supply = <&L9A>;
			jlq,cdc-vddpx-voltage = <1800000 1800000>;
			jlq,cdc-vddpx-current = <20000>;

			//cdc-vdd-buck-supply = <&L14A>;
			jlq,cdc-vdd-buck-voltage = <1800000 1800000>;
			jlq,cdc-vdd-buck-current = <650000>;

			jlq,cdc-micbias1-mv = <1800>;
			jlq,cdc-micbias2-mv = <1800>;
			jlq,cdc-micbias3-mv = <1800>;

			jlq,cdc-static-supplies = "cdc-vdd-rxtx",
						   "cdc-vddpx";
			jlq,cdc-on-demand-supplies = "cdc-vdd-buck";
		};
	};

	pcm0: jlq,msm-pcm {
		compatible = "jlq,msm-pcm-dsp";
		jlq,msm-pcm-dsp-id = <0>;
	};

	routing: jlq,msm-pcm-routing {
		compatible = "jlq,msm-pcm-routing";
	};

	compr: jlq,msm-compr-dsp {
		compatible = "jlq,msm-compr-dsp";
	};

	pcm1: jlq,msm-pcm-low-latency {
		compatible = "jlq,msm-pcm-dsp";
		jlq,msm-pcm-dsp-id = <1>;
		jlq,msm-pcm-low-latency;
		jlq,latency-level = "regular";
	};

	pcm2: jlq,msm-ultra-low-latency {
		compatible = "jlq,msm-pcm-dsp";
		jlq,msm-pcm-dsp-id = <2>;
		jlq,msm-pcm-low-latency;
		jlq,latency-level = "ultra";
	};

	pcm_noirq: jlq,msm-pcm-dsp-noirq {
		compatible = "jlq,msm-pcm-dsp-noirq";
		jlq,msm-pcm-low-latency;
		jlq,latency-level = "ultra";
	};

	trans_loopback: jlq,msm-transcode-loopback {
		compatible = "jlq,msm-transcode-loopback";
	};

	compress: jlq,msm-compress-dsp {
		compatible = "jlq,msm-compress-dsp";
	};

	voip: jlq,msm-voip-dsp {
		compatible = "jlq,msm-voip-dsp";
	};

	voice: jlq,msm-pcm-voice {
		compatible = "jlq,msm-pcm-voice";
		jlq,destroy-cvd;
	};

	stub_codec: jlq,msm-stub-codec {
		compatible = "jlq,msm-stub-codec";
	};

	jlq,msm-dai-fe {
		compatible = "jlq,msm-dai-fe";
	};

	afe: jlq,msm-pcm-afe {
		compatible = "jlq,msm-pcm-afe";
	};

	dai_hdmi: jlq,msm-dai-q6-hdmi {
		compatible = "jlq,msm-dai-q6-hdmi";
		jlq,msm-dai-q6-dev-id = <8>;
	};

	dai_dp: jlq,msm-dai-q6-dp {
		compatible = "jlq,msm-dai-q6-hdmi";
		jlq,msm-dai-q6-dev-id = <0>;
	};

	dai_dp1: jlq,msm-dai-q6-dp1 {
		compatible = "jlq,msm-dai-q6-hdmi";
		jlq,msm-dai-q6-dev-id = <1>;
	};

	loopback: jlq,msm-pcm-loopback {
		compatible = "jlq,msm-pcm-loopback";
	};

	loopback1: jlq,msm-pcm-loopback-low-latency {
		compatible = "jlq,msm-pcm-loopback";
		jlq,msm-pcm-loopback-low-latency;
	};

	pcm_dtmf: jlq,msm-pcm-dtmf {
		compatible = "jlq,msm-pcm-dtmf";
	};

	msm_dai_mi2s: jlq,msm-dai-mi2s {
		compatible = "jlq,msm-dai-mi2s";
		dai_mi2s0: jlq,msm-dai-q6-mi2s-prim {
			compatible = "jlq,msm-dai-q6-mi2s";
			jlq,msm-dai-q6-mi2s-dev-id = <0>;
			jlq,msm-mi2s-rx-lines = <3>;
			jlq,msm-mi2s-tx-lines = <0>;
		};

		dai_mi2s1: jlq,msm-dai-q6-mi2s-sec {
			compatible = "jlq,msm-dai-q6-mi2s";
			jlq,msm-dai-q6-mi2s-dev-id = <1>;
			jlq,msm-mi2s-rx-lines = <1>;
			jlq,msm-mi2s-tx-lines = <0>;
		};

		dai_mi2s2: jlq,msm-dai-q6-mi2s-tert {
			compatible = "jlq,msm-dai-q6-mi2s";
			jlq,msm-dai-q6-mi2s-dev-id = <2>;
			jlq,msm-mi2s-rx-lines = <0>;
			jlq,msm-mi2s-tx-lines = <3>;
		};

		dai_mi2s3: jlq,msm-dai-q6-mi2s-quat {
			compatible = "jlq,msm-dai-q6-mi2s";
			jlq,msm-dai-q6-mi2s-dev-id = <3>;
			jlq,msm-mi2s-rx-lines = <1>;
			jlq,msm-mi2s-tx-lines = <2>;
		};

		dai_mi2s4: jlq,msm-dai-q6-mi2s-quin {
			compatible = "jlq,msm-dai-q6-mi2s";
			jlq,msm-dai-q6-mi2s-dev-id = <4>;
			jlq,msm-mi2s-rx-lines = <1>;
			jlq,msm-mi2s-tx-lines = <2>;
		};

		dai_mi2s5: jlq,msm-dai-q6-mi2s-senary {
			compatible = "jlq,msm-dai-q6-mi2s";
			jlq,msm-dai-q6-mi2s-dev-id = <5>;
			jlq,msm-mi2s-rx-lines = <0>;
			jlq,msm-mi2s-tx-lines = <3>;
		};
	};

	msm_dai_cdc_dma: jlq,msm-dai-cdc-dma {
		compatible = "jlq,msm-dai-cdc-dma";
		wsa_cdc_dma_0_rx: jlq,msm-dai-wsa-cdc-dma-0-rx {
			compatible = "jlq,msm-dai-cdc-dma-dev";
			jlq,msm-dai-cdc-dma-dev-id = <45056>;
		};

		wsa_cdc_dma_0_tx: jlq,msm-dai-wsa-cdc-dma-0-tx {
			compatible = "jlq,msm-dai-cdc-dma-dev";
