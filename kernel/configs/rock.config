#=============================== BSP-System begin ===============================
CONFIG_LOCALVERSION="-perf"
CONFIG_LOCALVERSION_AUTO=y
CONFIG_MTK_THERMAL_AWARE_SCHEDULING=n
CONFIG_HQ_SYSFS_SUPPORT=m
CONFIG_SERIAL_NUM=m
CONFIG_SIMTRAY_STATUS=m
CONFIG_LOG_BUF_SHIFT=21
