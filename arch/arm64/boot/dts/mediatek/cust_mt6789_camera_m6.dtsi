		};
	};

	camera_pins_cam0_wl2866_vin_0: camera_pins_cam0_wl2866_vin_0@1 {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO21__FUNC_GPIO21>;
			slew-rate = <1>;
			output-low;
		};
	};
	camera_pins_cam0_wl2866_vin_1: camera_pins_cam0_wl2866_vin_1@2 {
		pins_cmd_dat {
