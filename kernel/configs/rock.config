CONFIG_NFC_PN553_DEVICES=m
#=================================== NFC end =====================================

#================================= Others begin ==================================
CONFIG_MIUI_ZRAM_MEMORY_TRACKING=y
CONFIG_ZRAM_WRITEBACK=y
