source "drivers/soc/jlq/nanohub/Kconfig"
source "drivers/soc/jlq/reset/Kconfig"
source "drivers/soc/jlq/usb/Kconfig"
source "drivers/soc/jlq/interconnect/Kconfig"
source "drivers/soc/jlq/vdsp/Kconfig"
source "drivers/soc/jlq/power/Kconfig"
source "drivers/soc/jlq/audio-kernel/Kconfig"
source "drivers/soc/jlq/devfreq/Kconfig"
source "drivers/soc/jlq/iio/Kconfig"
source "drivers/soc/jlq/thermal/Kconfig"
#source "drivers/soc/jlq/glink/Kconfig"
source "drivers/soc/jlq/i2s/Kconfig"
source "drivers/soc/jlq/crypto/Kconfig"
source "drivers/soc/jlq/sysdump/Kconfig"
source "drivers/soc/jlq/dcstat/Kconfig"
source "drivers/soc/jlq/touchscreen/Kconfig"
source "drivers/soc/jlq/tz/Kconfig"
source "drivers/soc/jlq/fingerprint/Kconfig"
source "drivers/soc/jlq/bluetooth/Kconfig"
source "drivers/soc/jlq/timer/Kconfig"
source "drivers/soc/jlq/pmctrl/Kconfig"
source "drivers/soc/jlq/blklog/Kconfig"
endmenu
