/* haptic */
&haptic2 {
	status = "okay";
	reset-gpios = <&dw_gpio3 24 1>;
	irq-gpio = <&dw_gpio2 3 0x0>;
	interrupt-parent = <&dw_gpio2>;
	interrupts = <3 IRQ_TYPE_LEVEL_LOW>;
	#cirrus,fw-defer = <1>;
	pinctrl-names = "default";
	pinctrl-0 = <&gpio_067_default>;
	//cirrus,vbbr-enable;
	cirrus,vbbr-thld-uv = <273000>;
	cirrus,vbbr-max-att-db = <9>;
	cirrus,vbbr-atk-step = <1>;
	cirrus,vbbr-atk-rate = <2>;
	cirrus,vbbr-wait = <1>;
	cirrus,vbbr-rel-rate = <5>;

	//cirrus,vpbr-enable;
	cirrus,vpbr-thld-uv = <2639000>;
	cirrus,vpbr-max-att-db = <9>;
	cirrus,vpbr-atk-step = <1>;
	cirrus,vpbr-atk-rate = <2>;
	cirrus,vpbr-wait = <1>;
	cirrus,vpbr-rel-rate = <5>;

	//cirrus,bst-dcm-en;

	cirrus,bst-ipk-microamp = <4500000>;
	cirrus,bst-ctl-microvolt = <11000000>;
	cirrus,clip-lvl-microvolt= <11000000>;

	//cirrus,ng-enable;
	cirrus,ng-thld = <3>;
	cirrus,ng-delay = <3>;

	//cirrus,aux-ng-enable;
	cirrus,aux-ng-thld = <3>;
	cirrus,aux-ng-delay = <3>;

	//cirrus,dc-wd-enable;
	cirrus,dc-wd-thld = <20>;
	cirrus,dc-wd-dur = <5>;
	cirrus,dc-wd-mute;
};

&cs35l41b {
	status = "disabled";
};

&cs47l92 {
	reset-gpios = <&dw_gpio3 0 0>;
	irq-gpio = <&dw_gpio1 29 0x0>;
	#interrupt-parent = <&dw_gpio1>;
	#interrupts = <29 IRQ_TYPE_LEVEL_LOW>;

	AVDD-supply = <&mldo8>;
	DBVDD1-supply = <&mldo8>;
};

&pinctrl_configs {
    i2s0_sck_init: i2s0_sck_init {
        mux {
            pins = "PAD_GPIO_066";
            function = "GPIO";
            };
        pinconf {
            pins = "PAD_GPIO_066";
            bias-pull-down;
            drive-strength= <2>;
            slew-rate= <0>;
            input-schmitt-disable;
            input-enable;
        };
    };
    i2s0_sck_default: i2s0_sck_default {
        mux {
            pins = "PAD_GPIO_066";
            function = "I2S0";
            };
        pinconf {
            pins = "PAD_GPIO_066";
            bias-disable;
            drive-strength= <2>;
            slew-rate= <0>;
            input-schmitt-disable;
        };
    };
