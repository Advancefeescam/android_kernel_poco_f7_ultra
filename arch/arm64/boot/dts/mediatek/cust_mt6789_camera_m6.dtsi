			output-high;
		};
	};
	camera_pins_cam2_wl2866_vin_0: camera_pins_cam2_wl2866_vin_0@5 {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO21__FUNC_GPIO21>;
			slew-rate = <1>;
			output-low;
		};
	};
	camera_pins_cam2_wl2866_vin_1: camera_pins_cam2_wl2866_vin_1@6 {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO21__FUNC_GPIO21>;
			slew-rate = <1>;
			output-high;
		};
	};

	camera_pins_cam3_wl2866_vin_0: camera_pins_cam3_wl2866_vin_0@7 {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO21__FUNC_GPIO21>;
			slew-rate = <1>;
			output-low;
		};
	};
	camera_pins_cam3_wl2866_vin_1: camera_pins_cam3_wl2866_vin_1@8 {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO21__FUNC_GPIO21>;
			slew-rate = <1>;
			output-high;
		};
	};
	camera_pins_cam_mipi_switch_en_1: camera_pins_cam_mipi_switch_en_cam2@1 {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO104__FUNC_GPIO104>;
