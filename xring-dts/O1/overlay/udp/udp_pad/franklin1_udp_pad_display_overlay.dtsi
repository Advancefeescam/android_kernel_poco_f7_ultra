&fake_dsi_panel {
	status = "okay";
	dsi-panel-port-mask = /bits/ 8 <0x01>; // 0001
	dsi-panel-idle-policy = <0x0>;
};

&xring_veu {
	status = "okay";
};

&pinctrl_configs {
	/* Only for display */
	gpio_074_work: gpio_074_work {
		mux {
			pins = "PAD_GPIO_074";
			function = "GPIO";
		};
		pinconf {
			pins = "PAD_GPIO_074";
			bias-disable;
			drive-strength= <1>;
			slew-rate= <0>;
			input-schmitt-disable;
		};
	};
	gpio_086_work: gpio_086_work {
		mux {
			pins = "PAD_GPIO_086";
			function = "GPIO";
		};
		pinconf {
			pins = "PAD_GPIO_086";
			bias-disable;
			drive-strength= <1>;
			slew-rate= <0>;
			input-schmitt-disable;
		};
	};
	gpio_136_work: gpio_136_work {
		mux {
			pins = "PAD_GPIO_136";
			function = "GPIO";
		};
		pinconf {
			pins = "PAD_GPIO_136";
			bias-disable;
			drive-strength= <1>;
			slew-rate= <0>;
			input-schmitt-disable;
		};
	};
	gpio_137_work: gpio_137_work {
		mux {
			pins = "PAD_GPIO_137";
			function = "GPIO";
		};
		pinconf {
			pins = "PAD_GPIO_137";
			bias-disable;
			drive-strength= <1>;
			slew-rate= <0>;
			input-schmitt-disable;
		};
	};
	gpio_144_work: gpio_144_work {
		mux {
			pins = "PAD_GPIO_144";
			function = "GPIO";
		};
		pinconf {
			pins = "PAD_GPIO_144";
			bias-disable;
			drive-strength= <1>;
			slew-rate= <0>;
			input-schmitt-disable;
		};
	};
};

&xring_dsi_display {
	/*
	 * 0: detect by lcd_name
	 * 1: detect by lcd_gpio_id
	 */
	lcd_detect_type = <0>;
	lcd_name = "dsi_panel_m81_dualdsi_dsc_lcd_video";
	lcd_gpio_id = <91>;
	lcd_vddio_id = <MPMIC_MLDO7>;
	lcd_id = <0>;

	scene_id = <0>;

	dsi-panel = <&dsi_panel_m81_dualdsi_dsc_lcd_video>,
			<&dsi_panel_o81_0a_dualdsi_dsc_lcd_video>,
			<&dsi_panel_o81_0b_dualdsi_dsc_lcd_video>,
			<&dsi_panel_k81_42_02_0a_video>,
			<&fake_dsi_panel>;
};
