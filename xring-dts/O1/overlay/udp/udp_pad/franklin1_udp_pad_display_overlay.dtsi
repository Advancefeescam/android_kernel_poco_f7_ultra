	dsi-panel-dvdd-en-gpio = <&dw_gpio3 5 0>; // 86
	dsi-panel-hw-en-gpio = <&dw_gpio4 31 0>; // 144
	dsi-panel-en-p-gpio = <&dw_gpio4 23 0>; // 136
	dsi-panel-en-n-gpio = <&dw_gpio4 24 0>; // 137

	dsi-panel-power-seq = "dsi-panel-vddio",
