	hostless: jlq,msm-pcm-hostless {
		compatible = "jlq,msm-pcm-hostless";
	};

	audio_apr: jlq,msm-audio-apr {
		compatible = "jlq,msm-audio-apr";
		jlq,subsys-name = "apr_adsp";
	};

	msm_audio_ion: jlq,msm-audio-ion {
		compatible = "jlq,msm-audio-ion";
		jlq,smmu-version = <2>;
		jlq,smmu-enabled;
	};

	dai_pri_auxpcm: jlq,msm-pri-auxpcm {
		compatible = "jlq,msm-auxpcm-dev";
		jlq,msm-cpudai-auxpcm-mode = <0>, <0>;
		jlq,msm-cpudai-auxpcm-sync = <1>, <1>;
		jlq,msm-cpudai-auxpcm-frame = <5>, <4>;
		jlq,msm-cpudai-auxpcm-quant = <2>, <2>;
		jlq,msm-cpudai-auxpcm-num-slots = <1>, <1>;
		jlq,msm-cpudai-auxpcm-slot-mapping = <1>, <1>;
		jlq,msm-cpudai-auxpcm-data = <0>, <0>;
		jlq,msm-cpudai-auxpcm-pcm-clk-rate = <2048000>, <2048000>;
		jlq,msm-auxpcm-interface = "primary";
		jlq,msm-cpudai-afe-clk-ver = <2>;
	};

	dai_sec_auxpcm: jlq,msm-sec-auxpcm {
		compatible = "jlq,msm-auxpcm-dev";
		jlq,msm-cpudai-auxpcm-mode = <0>, <0>;
