		// 		qcom,intents = <0x200 20>;
		// 	};

		// 	qcom,msm_fastrpc_rpmsg {
		// 		compatible = "qcom,msm-fastrpc-rpmsg";
		// 		qcom,glink-channels = "fastrpcglink-apps-dsp";
		// 		qcom,intents = <0x64 64>;
		// 	};

		// 	qcom,adsp_glink_ssr {
		// 		qcom,glink-channels = "glink_ssr";
		// 		qcom,notify-edges = <&glink_modem>,
		// 				    <&glink_cdsp>;
		// 	};
			};
	};

	qcom,glinkpkt {
		compatible = "qcom,glinkpkt";

		qcom,glinkpkt-at-mdm0 {
			qcom,glinkpkt-edge = "mpss";
			qcom,glinkpkt-ch-name = "DS";
			qcom,glinkpkt-dev-name = "at_mdm0";
		};

		qcom,glinkpkt-apr-apps2 {
			qcom,glinkpkt-edge = "adsp";
			qcom,glinkpkt-ch-name = "apr_apps2";
			qcom,glinkpkt-dev-name = "apr_apps2";
		};

		qcom,glinkpkt-data40-cntl {
			qcom,glinkpkt-edge = "mpss";
			qcom,glinkpkt-ch-name = "DATA40_CNTL";
			qcom,glinkpkt-dev-name = "smdcntl8";
		};

		qcom,glinkpkt-data1 {
			qcom,glinkpkt-edge = "mpss";
			qcom,glinkpkt-ch-name = "DATA1";
			qcom,glinkpkt-dev-name = "smd7";
		};

		qcom,glinkpkt-data4 {
			qcom,glinkpkt-edge = "mpss";
			qcom,glinkpkt-ch-name = "DATA4";
			qcom,glinkpkt-dev-name = "smd8";
		};

		qcom,glinkpkt-data11 {
			qcom,glinkpkt-edge = "mpss";
			qcom,glinkpkt-ch-name = "DATA11";
			qcom,glinkpkt-dev-name = "smd11";
		};

		qcom,glinkpkt-loopback-ctrl {
			qcom,glinkpkt-edge = "mpss";
			qcom,glinkpkt-ch-name = "LOOPBACK_CTL_MPSS";
			qcom,glinkpkt-dev-name = "glink_pkt_loopback_ctrl";
		};

		qcom,glinkpkt-loopback-data {
			qcom,glinkpkt-edge = "mpss";
			qcom,glinkpkt-ch-name = "LOOPBACK_DATA_MPSS";
			qcom,glinkpkt-dev-name = "glink_pkt_loopback";
		};

	};

	qcom,memshare {
		compatible = "qcom,memshare";

		qcom,client_1 {
			compatible = "qcom,memshare-peripheral";
			qcom,peripheral-size = <0x0>;
			qcom,client-id = <0>;
			qcom,allocate-boot-time;
			label = "modem";
		};

		qcom,client_2 {
			compatible = "qcom,memshare-peripheral";
			qcom,peripheral-size = <0x0>;
			qcom,client-id = <2>;
			label = "modem";
		};

		mem_client_3_size: qcom,client_3 {
			compatible = "qcom,memshare-peripheral";
			qcom,peripheral-size = <0x500000>;
			qcom,client-id = <1>;
			qcom,allocate-on-request;
			label = "modem";
		};
	};

	// qcom,smp2p_sleepstate {
	// 	compatible = "qcom,smp2p-sleepstate";
	// 	qcom,smem-states = <&sleepstate_smp2p_out 0>;
	// 	interrupt-parent = <&sleepstate_smp2p_in>;
	// 	interrupts = <0 0>;
	// 	interrupt-names = "smp2p-sleepstate-in";
	// };

	qcom,smp2p-modem {
		status = "okay";
		compatible = "qcom,smp2p";
		qcom,smem = <435>, <428>;
		interrupts = <GIC_SPI 119 IRQ_TYPE_EDGE_RISING>;
		mboxes = <&apcs_glb 2>;
		qcom,local-pid = <0>;
		qcom,remote-pid = <1>;

		modem_smp2p_out: master-kernel {
			qcom,entry-name = "master-kernel";
			#qcom,smem-state-cells = <1>;
		};

		modem_smp2p_in: slave-kernel {
			qcom,entry-name = "slave-kernel";
			interrupt-controller;
			#interrupt-cells = <2>;
		};

		smp2p_ipa_1_out: qcom,smp2p-ipa-1-out {
			qcom,entry-name = "ipa";
			#qcom,smem-state-cells = <1>;
		};

		/* ipa - inbound entry from mss */
		smp2p_ipa_1_in: qcom,smp2p-ipa-1-in {
			qcom,entry-name = "ipa";
			interrupt-controller;
			#interrupt-cells = <2>;
		};

		smp2p_wlan_1_in: qcom,smp2p-wlan-1-in {
			qcom,entry-name = "wlan";
			interrupt-controller;
			#interrupt-cells = <2>;
		};

	};

	pil_adsp {
		status = "ok";
		compatible = "qcom,pil-tz-generic";
		/* adsp unuse pil to load, just for probe and register sub sys */
		qcom,firmware-name = "adsp";
	};

	pil_imem{
		compatible = "qcom,msm-imem-pil-disable-timeout";
		reg = <0x24D00060 0x4>;
	};

	pil_modem: qcom,mss@24D00000 {
		status = "ok";
		compatible = "qcom,pil-tz-generic";
		reg = <0x24D00000 0x300B4>;
		reg-names = "rmb_base";

		clocks = <&rpmcc RPM_SMD_SNOC_CLK>, <&rpmcc RPM_SMD_CNOC_CLK>;
		clock-names = "qt_snoc", "qt_cnoc";
		qcom,proxy-clock-names = "qt_snoc", "qt_cnoc";
		qcom,qt_snoc-freq = <200000000>;
		qcom,qt_cnoc-freq = <75000000>;

		vdd_cx-supply = <&S4A_LEVEL>;
		vdd_mx-supply = <&S5A_LEVEL>;
		qcom,firmware-name = "modem";
		memory-region = <&pil_modem_mem>;
		qcom,msadp-region = <&pil_msadp_mem>;
		qcom,qbl-region = <&pil_qbl_mem>;
		qcom,proxy-timeout-ms = <10000>;
		qcom,sysmon-id = <0>;
		qcom,ssctl-instance-id = <0x12>;
		qcom,smem-id = <421>;
		qcom,minidump-id = <3>;
		qcom,aux-minidump-ids = <4>;
		qcom,complete-ramdump;
		//qcom,sequential-fw-load;
		qcom,tz_verify;

		/* Inputs from mss */
		interrupts-extended = <&gic 0 116 4>,
				<&gic 0 128 4>,//IRQ_TYPE_LEVEL_HIGH 4
				<&modem_smp2p_in 0 0>,
				<&modem_smp2p_in 2 0>,
				<&modem_smp2p_in 1 0>,
				<&modem_smp2p_in 3 0>,
				<&modem_smp2p_in 7 0>;

		interrupt-names = "qcom,qtang2-wdog",
				"qcom,wdog",
				"qcom,err-fatal",
				"qcom,proxy-unvote",
				"qcom,err-ready",
				"qcom,stop-ack",
				"qcom,shutdown-ack";

		/* Outputs to mss */
		qcom,smem-states = <&modem_smp2p_out 0>;
		qcom,smem-state-names = "qcom,force-stop";
	};

	jlq-cpufreq-qos {
		compatible = "jlq,cpufreq-qos";
	};

	jlq-blk-log{
		compatible = "jlq,blk-log-loader";
		jlq,blk-dev = "PARTLABEL=logdump";
		jlq,blklog-offset =  <0x800000>;
		jlq,blklog-maxsize = <0x200000>;
	};

	dc_stat0 {
		compatible = "jlq,dc-stat";
		lable = "cpu";
		cpu-supply = <&S1A>;
	};

	dc_stat1 {
		compatible = "jlq,dc-stat";
		lable = "ddr";
		ddr-supply = <&S8A>;
	};

	dc_stat2 {
		compatible = "jlq,dc-stat";
		lable = "core";
		core-supply = <&S3A_LEVEL>;
	};

	powerkey {
		compatible = "jlq,jlq-powerkey";
	};

	isr-monitor {
		compatible = "jlq,isr-monitor";
		irq-interval = <10>;
		max-irqs = <400>;
	};

	lpm_base: lpm_base@34510000 {
		compatible = "jlq,lpm-base";
		reg = <0x34510000 0x1000>;
		status = "disabled";
	};

	pwm0: pwm@30700000 {
		compatible = "jlq,jlq-pwm";
		reg = <0x30700000 0x40>;
		clocks = <&pwm_clk>, <&pwm0_pclk>;
		clock-names = "pwm_mclk", "pwm_pclk";
		#pwm-cells = <2>;
	};

	pwm1: pwm@30700040 {
		compatible = "jlq,jlq-pwm";
		reg = <0x30700040 0x40>;
		clocks = <&pwm_clk>, <&pwm0_pclk>;
		clock-names = "pwm_mclk", "pwm_pclk";
		#pwm-cells = <2>;
	};

	backlight: backlight {
		compatible = "jlq,jlq-backlight";
		pwm-names = "backlight";
		status = "disabled";
	};

	icnss: qcom,icnss@2C800000 {
		compatible = "qcom,icnss";
		reg = <0x2C800000 0x800000>;
		reg-names = "membase";
		interrupts = <GIC_SPI 160 IRQ_TYPE_LEVEL_HIGH /* CE0 */ >,
			     <GIC_SPI 161 IRQ_TYPE_LEVEL_HIGH /* CE1 */ >,
			     <GIC_SPI 162 IRQ_TYPE_LEVEL_HIGH /* CE2 */ >,
			     <GIC_SPI 163 IRQ_TYPE_LEVEL_HIGH /* CE3 */ >,
			     <GIC_SPI 164 IRQ_TYPE_LEVEL_HIGH /* CE4 */ >,
			     <GIC_SPI 165 IRQ_TYPE_LEVEL_HIGH /* CE5 */ >,
			     <GIC_SPI 166 IRQ_TYPE_LEVEL_HIGH /* CE6 */ >,
			     <GIC_SPI 167 IRQ_TYPE_LEVEL_HIGH /* CE7 */ >,
			     <GIC_SPI 168 IRQ_TYPE_LEVEL_HIGH /* CE8 */ >,
			     <GIC_SPI 169 IRQ_TYPE_LEVEL_HIGH /* CE9 */ >,
			     <GIC_SPI 170 IRQ_TYPE_LEVEL_HIGH /* CE10 */ >,
			     <GIC_SPI 171 IRQ_TYPE_LEVEL_HIGH /* CE11 */ >;
		qcom,wlan-msa-fixed-region = <&wlan_msa_mem>;
		vdd-cx-mx-supply = <&L8A>;
		vdd-1.8-xo-supply = <&L16A>;
		vdd-1.3-rfa-supply = <&L17A>;
		vdd-3.3-ch0-supply = <&L23A>;
		qcom,vdd-cx-mx-config = <640000 640000>;
		qcom,vdd-3.3-ch0-config = <3000000 3312000>;
		qcom,smp2p_map_wlan_1_in {
			interrupts-extended = <&smp2p_wlan_1_in 0 0>,
					      <&smp2p_wlan_1_in 1 0>;
			interrupt-names = "qcom,smp2p-force-fatal-error",
					  "qcom,smp2p-early-crash-ind";
		};
	};

	qcom,msm_gsi {/* resource from QTANGQRM-1075 */
		compatible = "qcom,msm_gsi";
	};

	qcom,rmnet-ipa {/* resource from QTANGQRM-1075 */
		compatible = "qcom,rmnet-ipa3";
		qcom,rmnet-ipa-ssr;
		qcom,ipa-platform-type-msm;
		qcom,ipa-advertise-sg-support;
		qcom,ipa-napi-enable;
	};

	ipa_hw: qcom,ipa@0x25800000 {
		compatible = "qcom,ipa";
		reg = <0x25800000 0x34000>,
			<0x25804000 0x28000>;
		reg-names = "ipa-base", "gsi-base";
		interrupts = <GIC_SPI 143 IRQ_TYPE_EDGE_RISING>,
					 <GIC_SPI 144 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "ipa-irq", "gsi-irq";
		qcom,ipa-hw-ver = <16>; /* IPA core version = IPAv4.2 */
		qcom,ipa-hw-mode = <0>;
		qcom,platform-type = <1>; /* MSM platform */
		qcom,ee = <0>;
		qcom,use-ipa-tethering-bridge;
		qcom,modem-cfg-emb-pipe-flt;
		qcom,ipa-wdi2;
		qcom,ipa-wdi2_over_gsi;
		qcom,ipa-endp-delay-wa;
		qcom,modem-load-ipa-fw;
		qcom,ipa-fltrt-not-hashable;
		qcom,fnr-stats-not-supported;
		qcom,use-64-bit-dma-mask;
		qcom,use-ipa-pm;
		qcom,skip-ieob-mask-wa;
		clocks = <&rpmcc RPM_SMD_IPA_CLK>, <&rpmcc RPM_SMD_SNOC_CLK>, <&rpmcc RPM_SMD_CNOC_CLK>;
		clock-names = "core_clk", "qt_snoc", "qt_cnoc";
		qcom,interconnect,num-cases = <5>;
		qcom,interconnect,num-paths = <2>;
		interconnects = <&qt_snoc MASTER_SNOC_IPA &qt_snoc SLAVE_SNOC_IPA>,
						<&qt_cnoc MASTER_CNOC_IPA &qt_cnoc SLAVE_CNOC_IPA>;
		interconnect-names = "ipa_to_ebi1", "appss_to_ipa";
		/* No vote */
		qcom,no-vote = <0 0 0 0>;
		/* SVS2 */
		qcom,svs2 = <80000 465000 80000 30>;
		/* SVS */
		qcom,svs =  <80000 2000000 80000 109890>;
		/* NOMINAL */
		qcom,nominal = <206000 4000000 206000 491520>;
		/* TURBO */
		qcom,turbo = <206000 5598900 206000 491520>;
		qcom,bus-vector-names = "MIN", "SVS2", "SVS", "NOMINAL", "TURBO";
		qcom,throughput-threshold = <310 600 1000>;
		qcom,scaling-exceptions = <>;

		/* smp2p information */
		qcom,smp2p_map_ipa_1_out {
			compatible = "qcom,smp2p-map-ipa-1-out";
			qcom,smem-states = <&smp2p_ipa_1_out 0>;
			qcom,smem-state-names = "ipa-smp2p-out";
		};

		qcom,smp2p_map_ipa_1_in {
			compatible = "qcom,smp2p-map-ipa-1-in";
			interrupts-extended = <&smp2p_ipa_1_in 0 IRQ_TYPE_EDGE_RISING>,
					      <&smp2p_ipa_1_in 1 IRQ_TYPE_EDGE_RISING>;
			interrupt-names = "ipa-smp2p-in", "ipa-fw-load-ready";
		};
	};

	jlq,jlq-adsp-log {
		compatible = "jlq,jlq-adsp-log";
		interrupt-parent = <&top_mbox_irq_adspnsec>;
		interrupts = <3 0>, <4 0>;
		interrupt-names = "log_app_interrupt", "log_point_interrupt";
	};


	/*slimbus bus fw*/
	slimbus_ctrl: slimbus_ctrl@340EA100 {
		compatible = "jlq,slimbus_ctrl";
		reg = <0x340EA100 0x10>;
	};

	slim_aud: slim@340e4000 {
		cell-index = <1>;
		compatible = "jlq,slim-controller";
		reg = <0x340e4000 0x2000>;
		reg-names = "slimbus_physical";
		interrupts = <GIC_SPI INT_SLIMBUS IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "slimbus_irq";
		slim-controller;
		clocks = <&slimbus_hclk>, <&slimbus_frm_clk_i>, <&slimbus_cport_clk_i>;
		clock-names = "slimbus_hclk", "slimbus_frm_clk_i", "slimbus_cport_clk_i";

		status = "ok";

		/*Slimbus Master for JR510*/
		masterslim-frd {
			compatible = "jlq,masterslim-frd";
			elemental-addr = [00 01 10 a5 45 04];
		};
		masterslim-ifd {
			compatible = "jlq,masterslim-ifd";
			elemental-addr = [00 00 10 a5 45 04];
		};
		masterslim-gd {
			compatible = "jlq,masterslim-gd";
			elemental-addr = [00 02 10 a5 45 04];
		};

		/*Slimbus Slave for WCN3950*/
		btfmslim_codec: wcn3950 {
			compatible = "qcom,btfmslim_slave";
			elemental-addr = [00 01 20 02 17 02];
			qcom,btfm-slim-ifd = "btfmslim_slave_ifd";
			qcom,btfm-slim-ifd-elemental-addr = [00 00 20 02 17 02];
		};
		/*Slimbus Slave for WCD9306*/
		/*
		btfmslim_codec: wcd9306 {
			compatible = "qcom,btfmslim_slave";
			elemental-addr = [00 01 e0 00 17 02];
			qcom,btfm-slim-ifd = "btfmslim_slave_ifd";
			qcom,btfm-slim-ifd-elemental-addr = [00 00 e0 00 17 02];
		};*/
	};

	bluetooth: bt_wcn3990 {
		compatible = "qcom,wcn3990";
		qcom,bt-sw-ctrl-gpio = <&qtang_gpio 59 GPIO_ACTIVE_HIGH>;
		qcom,bt-vdd-io-supply = <&L9A>;  /* IO */
		qcom,bt-vdd-core-supply = <&L17A>; /* RFA */
		qcom,bt-vdd-pa-supply = <&L23A>; /* CH0 */
		qcom,bt-vdd-xtal-supply = <&L16A>; /* XO */

		qcom,bt-vdd-io-config = <1700000 1900000 1 0>;
		qcom,bt-vdd-core-config = <1304000 1304000 1 0>;
		qcom,bt-vdd-pa-config = <3000000 3312000 1 0>;
		qcom,bt-vdd-xtal-config = <1700000 1900000 1 0>;
	};

	rpm_bus: qcom,rpm-smd {
		compatible = "qcom,rpm-smd";
		rpm-channel-name = "rpm_requests";
		interrupts = <GIC_SPI 153 IRQ_TYPE_EDGE_RISING>;
		rpm-channel-type = <15>; /* SMD_APPS_RPM */
	};

	spmi_bus: qcom,spmi@21c40000 {
		compatible = "qcom,spmi-pmic-arb";
		reg = <0x21c40000 0x1100>,
			<0x21e00000 0x2000000>,
			<0x23e00000 0x100000>,
			<0x23f00000 0xa0000>,
			<0x21c0a000 0x26000>;
		reg-names = "core", "chnls", "obsrvr", "intr", "cnfg";
		interrupt-names = "periph_irq";
		interrupts = <GIC_SPI 203 IRQ_TYPE_LEVEL_HIGH>;
		qcom,ee = <0>;
		qcom,channel = <0>;
		#address-cells = <1>;
		#size-cells = <1>;
		interrupt-controller;
		#interrupt-cells = <4>;
		cell-index = <0>;
	};

	smmu_tbu_gdsc: jlq,gdsc@34510280 {
		compatible = "jlq,gdsc";
		reg = <0x34510280 0x4>;
		regulator-name = "smmu_tbu_gdsc";
		jlq,use-qchannel;
		jlq,enable-value = <0x120002>;
		jlq,disable-value = <0x110001>;
		jlq,retry-count = <300>;
	};

	smmu_tcu_gdsc: jlq,gdsc@34510290 {
		compatible = "jlq,gdsc";
		reg = <0x34510290 0x4>;
		regulator-name = "smmu_tcu_gdsc";
		jlq,use-qchannel;
		jlq,enable-value = <0x120002>;
		jlq,disable-value = <0x110001>;
		jlq,retry-count = <300>;
	};

	sysdump: sysdump@0x34511300 {
		compatible = "jlq,sysdump";
		reg = <0x34511300 0x20>,
			<0xA2100000 0x80000>,
			<0x33000000 0x80000>;
		memory-region = <&sdi_mem>, <&cm4_dump_mem>;
		reg-names = "shutdown_reg", "cm4_dump", "cm4_ram";
		enable_sysdump;
		force-dump-gpio = <&gpio 43 GPIO_ACTIVE_HIGH>;
		interrupt-names = "abnormal_irq", "cm4_wdog_bite";
		interrupts = <GIC_SPI INT_QTANG_ABORT_RST IRQ_TYPE_LEVEL_HIGH>,
			 <GIC_SPI INT_WDT2_BITE IRQ_TYPE_LEVEL_HIGH>;
		mini_dump_size = <0x20000>;
		mini_dump_region = <0x34458000 0x400>, <0x34459000 0x40>;
		/*
			<0x30090000 0x34>, <0x30340000 0x40>,
			<0x30501000 0x28>, <0x30621000 0xb0>;
		*/
	};

	jlq-socinfo {
		compatible = "jlq,socinfo";
	};

	jlq-cpufreq-dcstat {
		compatible = "jlq,cpufreq-dcstat";
	};

	dummy:dummy@0x3450e0c4 {
		reg = <0x3450e0c4 0xc0>;
		compatible = "jlq,dummy";
		interrupt-names = "top_sysctl_irq";
		interrupts = <GIC_SPI INT_TOP_SYS_CTL IRQ_TYPE_LEVEL_HIGH>;
		dummy-slaves = "ai", "gpu", "vpu", "display", "vdsp";
		dummy-rpt-id = <0 1 4 2 3>;
	};

	jlq-devfreq-cpufreq {
		compatible = "jlq,devfreq-cpufreq";
	};

	pmctrl-sw0 {
		compatible = "jlq,pmctrl-opp";
		vdd_core-supply = <&S3A_LEVEL>;
		vdd_ddr-supply = <&S8A>;
		opp-supplies = <DDR_SW0_CLK>;
		operating-points-v2 = <&bus_sw0_opp_table>;
	};

	pmctrl-qxm0 {
		compatible = "jlq,pmctrl-opp";
		vdd_core-supply = <&S3A_LEVEL>;
		vdd_ddr-supply = <&S8A>;
		opp-supplies = <QTANG_XM0_CLK>;
		operating-points-v2 = <&bus_xm0_opp_table>;
	};

	pmctrl-qxm1 {
		compatible = "jlq,pmctrl-opp";
		vdd_core-supply = <&S3A_LEVEL>;
		opp-supplies = <QTANG_XM1_CLK>;
		operating-points-v2 = <&bus_xm1_opp_table>;
	};

	pmctrl-ddr {
		compatible = "jlq,pmctrl-opp";
		vdd_core-supply = <&S3A_LEVEL>;
		vdd_ddr-supply = <&S8A>;
		opp-supplies = <DDR_DFS_CLK>;
		operating-points-v2 = <&ddr_dfs_opp_table>;
	};

	pll-power {
		compatible = "jlq,pll-power";
		supply_0-supply = <&L12A>;
		jlq,supply_0 = <1800000 1800000>;
		supply_1-supply = <&L2A>;
		jlq,supply_1 = <800000 800000>;
		supply_2-supply = <&L3A_LEVEL>;
		jlq,supply_2 = <800000 800000>;
	};

	cpufreq-proc {
		compatible = "jlq,cpufreq-proc";
	};
};
#include "jr510_pinctrl_base.dtsi"
#include "jr510_qtang_pinctrl_base.dtsi"
#include "bengal-gdsc.dtsi"
#include "pm6125.dtsi"
#include "jlq-pm6125.dtsi"
#include "pm6125-rpm-regulator.dtsi"
#include "bengal-regulator.dtsi"

#include "jr510_camera.dtsi"
#include "jr510-bus.dtsi"
#include "jr510_clock.dtsi"
#include "jr510_coresight.dtsi"
#include "jr510_i2c.dtsi"
#include "jr510_display.dtsi"
#include "jr510_audio.dtsi"

#include "jr510-thermal.dtsi"
#include "jr510_thermal_modem.dtsi"
#include "jr510_thermal_camera.dtsi"
#include "jr510_thermal_charge.dtsi"
#include "pm6125_adc_tz_c3mn.dtsi"
#include "jr510_ssi.dtsi"
#include "jr510_ddr_dvfs.dtsi"
#include "jr510_pm.dtsi"

&dp0 {
	logo-memory = <&logo_mem_region>;
};

&pm6125_gpios {
	key_vol_up {
		key_vol_up_default: key_vol_up_default {
			pins = "gpio5";
			function = "normal";
			input-enable;
			bias-pull-up;
			power-source = <0>;
		};
	};
};

&soc {
	gpio_keys {
		compatible = "gpio-keys";
		label = "gpio-keys";

		pinctrl-names = "default";
		pinctrl-0 = <&key_vol_up_default>;

		vol_up {
			label = "volume_up";
			gpios = <&pm6125_gpios 5 GPIO_ACTIVE_LOW>;
			linux,input-type = <1>;
			linux,code = <KEY_VOLUMEUP>;
			linux,can-disable;
			debounce-interval = <15>;
			gpio-key,wakeup;
		};
	};
        ant_check {
		compatible = "ant_check";
		ant_check_gpio = <&gpio 6 0x0>;
	};
	ant_check_div {
		compatible = "ant_check_div";
		ant_check_div_gpio = <&gpio 36 0x0>;
	};
};


&i2c_3{
	pinctrl-names = "default";
	pinctrl-0 = <&i2c3_pins>;
};

&i2c_4{
	pinctrl-names = "default";
