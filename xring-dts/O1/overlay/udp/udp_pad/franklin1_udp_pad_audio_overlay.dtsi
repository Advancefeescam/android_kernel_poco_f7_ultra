&spk1 {
	status = "okay";
	reset-gpios = <&dw_gpio5 24 0>;
	irq-gpio = <&dw_gpio4 11 0x0>;
	#interrupt-parent = <&dw_gpio4>;
	#interrupts = <11 IRQ_TYPE_LEVEL_LOW>;
	cirrus,gpio2-src-sel = <2>;
	sound-name-prefix = "B1";
};

&spk2 {
	status = "okay";
	reset-gpios = <&dw_gpio5 24 0>;
	irq-gpio = <&dw_gpio4 12 0x0>;
	#interrupt-parent = <&dw_gpio4>;
	#interrupts = <12 IRQ_TYPE_LEVEL_LOW>;
	cirrus,gpio2-src-sel = <2>;
	sound-name-prefix = "B2";
};

&spk3 {
	status = "okay";
	reset-gpios = <&dw_gpio5 24 0>;
	irq-gpio = <&dw_gpio4 30 0x0>;
	#interrupt-parent = <&dw_gpio4>;
	#interrupts = <30 IRQ_TYPE_LEVEL_LOW>;
	cirrus,gpio2-src-sel = <2>;
	sound-name-prefix = "B3";
	sound-channel = <2>;
	cirrus,i2c-addr = <41>;
	cirrus,low-pwr-mode-standby = <1>;
	cirrus,vpbr-enable = <1>;
	cirrus,vpbr-rel-rate = <0>;
	cirrus,vpbr-wait = <0>;
	cirrus,vpbr-atk-rate = <0>;
	cirrus,vpbr-atk-vol = <0x5>;
	cirrus,vpbr-max-att = <0x3>;
	cirrus,vpbr-thld = <0x8>;
};

&spk4 {
	status = "okay";
	reset-gpios = <&dw_gpio5 24 0>;
	irq-gpio = <&dw_gpio5 29 0x0>;
	#interrupt-parent = <&dw_gpio4>;
	#interrupts = <29 IRQ_TYPE_LEVEL_LOW>;
	cirrus,gpio2-src-sel = <2>;
	sound-channel = <3>;
	sound-name-prefix = "B4";
	cirrus,i2c-addr = <43>;
	cirrus,low-pwr-mode-standby = <1>;
	cirrus,vpbr-enable = <1>;
	cirrus,vpbr-rel-rate = <0>;
	cirrus,vpbr-wait = <0>;
	cirrus,vpbr-atk-rate = <0>;
	cirrus,vpbr-atk-vol = <0x5>;
	cirrus,vpbr-max-att = <0x3>;
	cirrus,vpbr-thld = <0x8>;
};

&spk5 {
	status = "okay";
	reset-gpios = <&dw_gpio5 24 0>;
	irq-gpio = <&dw_gpio4 9 0x0>;
	#interrupt-parent = <&dw_gpio4>;
	#interrupts = <9 IRQ_TYPE_LEVEL_LOW>;
	cirrus,gpio2-src-sel = <2>;
	sound-channel = <0>;
	sound-name-prefix = "T1";
	cirrus,i2c-addr = <40>;
	cirrus,low-pwr-mode-standby = <1>;
	cirrus,vpbr-enable = <1>;
	cirrus,vpbr-rel-rate = <0>;
	cirrus,vpbr-wait = <0>;
	cirrus,vpbr-atk-rate = <0>;
	cirrus,vpbr-atk-vol = <0x5>;
	cirrus,vpbr-max-att = <0x3>;
	cirrus,vpbr-thld = <0x8>;
};

